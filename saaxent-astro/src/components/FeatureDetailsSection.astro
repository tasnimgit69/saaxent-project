---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import { featureDetailItems } from '../data/features-details';

const { feature } = Astro.props;
const allFeatures = featureDetailItems;
---

<section class="relative pt-90 min-1280:pt-110 min-1440:pt-130 max-991:pt-70 max-767:pt-50">
  <Container>
    <div class="relative z-10 flex items-start gap-40 max-991:flex-col">
      {/* Sidebar */}
      <div class="sidebar-block reveal">
        <div class="sidebar-title-block">
          <div class="sidebar-title">Features</div>
        </div>
        <div class="sidebar-list-wrap">
          <div class="sidebar-list">
            {allFeatures.map((f) => (
              <a
                href={`/features/${f.slug}`}
                class={`sidebar-link${f.slug === feature.slug ? ' active' : ''}`}
              >
                <span class="sidebar-link-name">{f.tag}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M5.35938 19L11.1224 13.237C11.2862 13.0753 11.4163 12.8827 11.505 12.6704C11.5938 12.458 11.6395 12.2302 11.6395 12C11.6395 11.7698 11.5938 11.542 11.505 11.3296C11.4163 11.1173 11.2862 10.9247 11.1224 10.763L5.35938 5M12.3594 19L18.1224 13.237C18.2862 13.0753 18.4163 12.8827 18.505 12.6704C18.5938 12.458 18.6395 12.2302 18.6395 12C18.6395 11.7698 18.5938 11.542 18.505 11.3296C18.4163 11.1173 18.2862 10.9247 18.1224 10.763L12.3594 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* Main Content */}
      <div class="flex-1">
        <div class="reveal delay-1">
          <h2>{feature.title}</h2>
          <p class="mt-16 text-ink-body">{feature.excerpt}</p>
        </div>

        <div class="mt-32 reveal delay-1">
          <div class="prose prose-invert max-w-none text-ink-body [&_h3]:mt-32 [&_h3]:mb-16 [&_h3]:text-ink-heading [&_h3]:font-semibold [&_p]:mb-16 [&_p]:leading-relaxed" set:html={feature.bodyPart1} />
        </div>

        {/* Gallery */}
        {feature.gallery.length > 0 && (
          <div class={`mt-32 grid gap-16 ${feature.gallery.length > 1 ? 'grid-cols-2 max-767:grid-cols-1' : 'grid-cols-1'} reveal delay-2`}>
            {feature.gallery.map((img) => (
              <Image
                src={img.src}
                alt={img.alt}
                class="h-auto w-full rounded-16"
                width={400}
                height={280}
              />
            ))}
          </div>
        )}

        <div class="mt-32 reveal delay-2">
          <div class="prose prose-invert max-w-none text-ink-body [&_h3]:mt-32 [&_h3]:mb-16 [&_h3]:text-ink-heading [&_h3]:font-semibold [&_p]:mb-16 [&_p]:leading-relaxed" set:html={feature.bodyPart2} />
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  /* ===== Sidebar Block ===== */
  .sidebar-block {
    border: 1px solid #dcdcdc;
    border-radius: 16px;
    flex: none;
    width: 380px;
    padding: 30px;
    position: sticky;
    top: 120px;
  }

  /* ===== Title Block ===== */
  .sidebar-title-block {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .sidebar-title {
    color: #fff;
    font-size: 28px;
    font-weight: 500;
    line-height: 1.27;
  }

  /* ===== List ===== */
  .sidebar-list-wrap {
    margin-top: 24px;
    overflow: hidden;
  }

  .sidebar-list {
    display: flex;
    flex-flow: column;
    gap: 24px;
  }

  /* ===== Link ===== */
  .sidebar-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #fff;
    color: #031422;
    border-radius: 16px;
    padding: 13px 16px;
    font-size: 20px;
    line-height: 1.4;
    text-decoration: none;
    transition: background-color 0.3s, color 0.3s;
  }

  .sidebar-link:hover,
  .sidebar-link.active {
    background-color: #5542f6;
    color: #fff;
  }

  /* ============= min-1440 ============= */
  @media (min-width: 1440px) {
    .sidebar-block {
      width: 410px;
    }

    .sidebar-title {
      font-size: 36px;
    }

    .sidebar-list {
      gap: 32px;
    }

    .sidebar-link {
      padding: 14px 20px;
    }
  }

  /* ============= min-1920 ============= */
  @media (min-width: 1920px) {
    .sidebar-block {
      padding: 40px;
    }
  }

  /* ============= max-991 ============= */
  @media (max-width: 991px) {
    .sidebar-block {
      width: 100%;
      padding: 30px;
      position: static;
      box-sizing: border-box;
    }

    .sidebar-list-wrap {
      margin-top: 24px;
    }

    .sidebar-list {
      display: grid;
      grid-template-rows: auto auto;
      grid-template-columns: 1fr 1fr;
      grid-auto-columns: 1fr;
      gap: 20px;
    }

    .sidebar-link {
      padding: 24px;
    }
  }

  /* ============= max-767 ============= */
  @media (max-width: 767px) {
    .sidebar-block {
      padding: 20px;
    }

    .sidebar-title {
      font-size: 24px;
    }

    .sidebar-list-wrap {
      margin-top: 16px;
    }

    .sidebar-list {
      grid-template-columns: 1fr;
    }

    .sidebar-link {
      padding: 20px 16px;
    }
  }

  /* ============= max-479 ============= */
  @media (max-width: 479px) {
    .sidebar-block {
      padding: 16px;
    }

    .sidebar-title {
      font-size: 22px;
    }

    .sidebar-link {
      padding-top: 14px;
      padding-bottom: 14px;
    }

    .sidebar-link-name {
      font-size: 18px;
    }
  }
</style>
