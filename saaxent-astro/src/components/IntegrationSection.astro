---
import Container from "./Container.astro";
import PrimaryButton from "./PrimaryButton.astro";
import { integrationSection } from "../data/home-v1";
---

<section
  class="bg-surface-primary relative overflow-hidden py-90 min-1280:py-110 min-1440:py-130 max-991:py-70 max-767:py-50"
>
  <Container>
    <div class="relative z-10">
      <div class="integration-wrapper">
        <!-- Left: Content Block -->
        <div class="integration-content-block">
          <div class="reveal">
            <span
              class="mb-20 inline-block rounded-19 bg-brand-primary px-20 py-4 font-sans text-sm font-medium text-white"
            >
              {integrationSection.badge}
            </span>
          </div>
          <h2 class="reveal delay-1">
            {integrationSection.title}{" "}
            <span
              class="inline-flex items-center justify-center bg-[url('/images/title-highlight-shape.svg')] bg-[position:50%_80%] bg-no-repeat bg-[length:100%]"
            >
              {integrationSection.titleHighlight}
            </span>
            {
              integrationSection.titleAfter &&
                ` ${integrationSection.titleAfter}`
            }
          </h2>
          <p class="mt-20 reveal delay-2">{integrationSection.description}</p>
          <div class="mt-40 max-991:mt-20 reveal delay-3">
            <PrimaryButton href={integrationSection.cta.href}>
              {integrationSection.cta.label}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="23"
                height="18"
                viewBox="0 0 23 18"
                fill="none"
                class="ml-10"
              >
                <g clip-path="url(#clip_int_arrow)">
                  <path
                    d="M21.0834 9.0376L13.8959 1.8501M21.0834 9.0376L13.8959 16.2251M21.0834 9.0376L8.50525 9.0376M1.91671 9.0376L4.9115 9.0376"
                    stroke="currentColor"
                    stroke-width="1.79688"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </g>
                <defs>
                  <clipPath id="clip_int_arrow">
                    <rect
                      width="17.25"
                      height="23"
                      fill="currentColor"
                      transform="translate(23 0.412598) rotate(90)"></rect>
                  </clipPath>
                </defs>
              </svg>
            </PrimaryButton>
          </div>
        </div>

        <!-- Right: Circle Animation Block -->
        <div class="integration-circle-animation-block relative">
          <div class="integration-items-logo-block reveal-grow delay-2">
            <div class="integration-circle-wrap">
              <!-- Circle One (outer) — spins clockwise -->
