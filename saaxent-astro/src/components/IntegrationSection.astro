<style>
  /* === Grid Layout === */
  .integration-wrapper {
    grid-column-gap: 40px;
    grid-row-gap: 40px;
    grid-template-rows: auto;
    grid-template-columns: 1fr 1fr;
    grid-auto-columns: 1fr;
    place-items: center stretch;
    display: grid;
  }

  /* === Content Block === */
  .integration-content-block {
    max-width: 500px;
  }

  /* === Circle Wrap === */
  .integration-circle-wrap {
    z-index: 1;
    width: 480px;
    height: 480px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .integration-items-logo-block {
    position: relative;
  }

  /* === All circles base === */
  .integration-circle {
    border: 2px dashed rgba(255, 255, 255, 0.2);
    border-radius: 100%;
  }

  /* === Circle One (outer) === */
  .circle-one {
    width: 420px;
    height: 420px;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  /* === Circle Two (middle) === */
  .circle-two {
    width: 260px;
    height: 260px;
    margin: auto;
    position: absolute;
    inset: 0%;
    justify-content: center;
    align-items: center;
  }

  /* === Circle Three (inner) === */
  .circle-three {
    width: 160px;
    height: 160px;
    position: absolute;
    inset: 0;
    margin: auto;
  }

  /* === Circle Four (center logo) === */
  .circle-four {
    z-index: 3;
    background-color: #ffffff;
    border-style: solid;
    border-color: rgba(255, 255, 255, 0.2);
    border-radius: 47px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 97px;
    height: 97px;
    display: flex;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* === Brand Icon Blocks (circle-one icons) === */
  .brand-icon-block {
    background-color: #ffffff;
    border-radius: 29px;
    justify-content: center;
    align-items: center;
    width: 58px;
    height: 58px;
    display: flex;
    position: absolute;
  }

  .brand-icon {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .brand-icon-block.one {
    top: -10px;
    left: 80px;
  }
  .brand-icon-block.two {
    top: 160px;
    left: -25px;
  }
  .brand-icon-block.three {
    top: auto;
    bottom: 30px;
    left: 35px;
  }
  .brand-icon-block.four {
    bottom: 83px;
    right: -10px;
  }
  .brand-icon-block.five {
    top: 51px;
    right: 0;
  }

  /* === Brand Icon Blocks Two (circle-two icons) === */
  .brand-icon-block-two {
    background-color: #ffffff;
    border-radius: 29px;
    justify-content: center;
    align-items: center;
    width: 58px;
    height: 58px;
    display: flex;
    position: absolute;
  }

  .brand-icon-block-two.one {
    margin-left: auto;
    margin-right: auto;
    top: -25px;
    left: 0;
    right: 0;
  }

  .brand-icon-block-two.two {
    margin: auto auto auto 0;
    inset: 0 auto 0 -25px;
  }

  .brand-icon-block-two.three {
    margin: auto auto 0;
    inset: 0 0 -25px;
  }

  .brand-icon-block-two.four {
    margin: auto 0 auto auto;
    inset: 0 -25px 0 0;
  }

  /* === Circle Background Glow === */
  .integration-circle-bg {
    background-color: #5542f6;
    opacity: 0.8;
    filter: blur(300px);
    border-radius: 100%;
    width: 180px;
    height: 180px;
    margin: auto;
    position: absolute;
    inset: 0;
  }

  /* === SVG Grid Patterns === */
  .left-block-shape {
    max-width: 500px;
    max-height: 600px;
    position: absolute;
    top: 0;
    left: 0;
  }

