---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import { aboutV2 } from '../data/home-v2';
---

<section class="about-us-v2-section bg-surface-primary relative overflow-hidden py-90 min-1280:py-110 min-1440:py-130 max-991:py-70 max-767:py-50">
  <Container>
    <div class="relative z-[1]">
      <div class="aboutv2-wrapper flex justify-between items-center">

        <!-- Left: Content Block -->
        <div>
          <!-- Badge -->
          <div class="reveal inline-block rounded-19 bg-brand-primary px-20 py-4 font-sans text-sm font-medium text-white mb-16 max-479:mb-10 max-767:mb-10">
            {aboutV2.badge}
          </div>

          <!-- Title -->
          <h2 class="aboutv2-section-title reveal delay-1 text-white mt-0 mb-10">
            {aboutV2.title}{' '}
            <span class="bg-[url('/images/section-title-highlight-shape.svg')] bg-[position:50%_90%] bg-no-repeat bg-[length:100%] min-1280:bg-[position:50%_83%]">
              {aboutV2.titleHighlight}
            </span>
          </h2>

          <!-- Excerpt -->
          <p class="aboutv2-excerpt reveal delay-2 mt-16 max-479:mt-10">
            {aboutV2.description}
          </p>

          <!-- List -->
          <ul class="aboutv2-list-block reveal delay-3 flex flex-col mb-0 pl-0 list-none">
            {aboutV2.listItems.map((item) => (
              <li class="aboutv2-list-item text-white bg-[url('/images/list-check-mark.svg')] bg-no-repeat bg-[position:0_0] leading-[1.4] max-767:bg-[position:0_2px] max-767:bg-[size:20px]">
                {item}
              </li>
            ))}
          </ul>

          <!-- Fun Facts -->
          <div class="funfact-v2-wrapper reveal delay-4 flex justify-between items-stretch">
            {aboutV2.stats.map((stat) => (
              <div class="funfact-v2-item flex flex-col items-start max-767:items-center">
                <span
                  class="text-[28px] font-medium leading-none text-white"
                  data-counter={stat.value}
                  data-counter-suffix={stat.suffix}
                >
                  0{stat.suffix}
                </span>
                <div class="funfact-v2-label">{stat.label}</div>
              </div>
            ))}
          </div>

          <!-- CTA Button -->
          <div class="aboutv2-btn-wrap reveal delay-5 flex items-center justify-start">
            <a
              href={aboutV2.cta.href}
              class="aboutv2-inline-primary inline-flex items-center justify-center border-2 border-solid border-brand-primary bg-brand-primary text-white rounded-40 px-22 py-13 text-h4 font-normal no-underline relative overflow-hidden transition-colors duration-[400ms] hover:text-brand-primary before:content-[''] before:absolute before:inset-0 before:bg-white before:rounded-40 before:-translate-x-full before:transition-transform before:duration-[400ms] hover:before:translate-x-0 min-1280:px-28 min-1280:py-15 min-1440:py-16 max-991:text-[22px] max-767:px-20 max-767:text-[20px] max-479:px-18 max-479:py-11 max-479:text-[18px]"
            >
              <span class="relative z-[2] flex items-center justify-center gap-10 max-767:gap-6">
                <span>{aboutV2.cta.label}</span>
                <span class="flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="23" height="18" viewBox="0 0 23 18" fill="none">
                    <g clip-path="url(#clip0_aboutv2_cta)">
                      <path d="M21.0834 9.0376L13.8959 1.8501M21.0834 9.0376L13.8959 16.2251M21.0834 9.0376L8.50525 9.0376M1.91671 9.0376L4.9115 9.0376" stroke="currentColor" stroke-width="1.79688" stroke-linecap="round" stroke-linejoin="round" />
                    </g>
                    <defs>
                      <clipPath id="clip0_aboutv2_cta">
                        <rect width="17.25" height="23" fill="currentColor" transform="translate(23 0.412598) rotate(90)" />
                      </clipPath>
                    </defs>
                  </svg>
                </span>
              </span>
            </a>
          </div>
        </div>

        <!-- Right: Banner Block -->
        <div class="aboutv2-banner-block relative reveal delay-2">
          {typeof aboutV2.images.banner.src !== 'string' && (
            <Image
              src={aboutV2.images.banner.src}
              alt={aboutV2.images.banner.alt}
              class="aboutv2-banner rounded-14 h-auto max-w-full"
            />
          )}
          {typeof aboutV2.images.overlay.src !== 'string' && (
            <Image
              src={aboutV2.images.overlay.src}
              alt={aboutV2.images.overlay.alt}
              class="aboutv2-overlay-img h-auto"
            />
          )}
        </div>

      </div>
    </div>
  </Container>

  <!-- Decorative background shapes -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Left grid SVG -->
    <div class="absolute top-0 left-0 max-w-[500px] max-h-[600px] min-1280:max-w-[600px] min-1280:max-h-[700px] min-1440:max-w-none min-1440:max-h-none max-991:max-w-[500px] max-991:max-h-[500px] max-767:max-w-[300px] max-767:max-h-[400px] max-479:max-w-[200px] max-479:max-h-[300px]">
      <svg xmlns="http://www.w3.org/2000/svg" width="634" height="957" viewBox="0 0 634 957" fill="none">
        <path d="M158.16 797.5H0L6.98403e-06 957H158.16V797.5ZM158.16 797.5L158.16 638M158.16 797.5L316.321 797.5L316.321 638H158.16M158.16 638L158.16 478.5M158.16 638L1.15188e-05 638L4.53472e-06 478.5H158.16M158.16 478.5L158.16 319M158.16 478.5L316.321 478.5L316.321 319H158.16M158.16 319L158.16 159.501M158.16 319L1.15188e-05 319.001L4.53472e-06 159.501L158.16 159.501M158.16 159.501L158.16 6.90146e-06L316.321 0L316.321 159.5L158.16 159.501ZM474.84 797.5H316.68V957H474.84V797.5ZM474.84 797.5L474.84 638M474.84 797.5L633 797.5V638H474.84M474.84 638L474.84 478.5M474.84 638L316.68 638V478.5H474.84M474.84 478.5L474.84 319M474.84 478.5L633 478.5V319L474.84 319M474.84 319L474.84 159.501M474.84 319L316.68 319.001V159.501L474.84 159.501M474.84 159.501L474.84 4.64542e-05L633 3.95528e-05V159.5L474.84 159.501Z" stroke="url(#paint0_linear_aboutv2_left)" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round" />
        <defs>
          <linearGradient id="paint0_linear_aboutv2_left" x1="633.02" y1="396.992" x2="9.48067e-05" y2="400.841" gradientUnits="userSpaceOnUse">
            <stop stop-color="white" stop-opacity="0" />
            <stop offset="1" stop-color="white" stop-opacity="0.05" />
          </linearGradient>
        </defs>
      </svg>
    </div>

    <!-- Right grid SVG -->
    <div class="absolute top-0 right-0 max-w-[500px] max-h-[600px] min-1280:max-w-[600px] min-1280:max-h-[700px] min-1440:max-w-none min-1440:max-h-none max-991:max-w-[400px] max-991:max-h-[500px] max-991:top-auto max-991:bottom-0 max-767:max-w-[300px] max-767:max-h-[400px] max-479:max-w-[200px] max-479:max-h-[300px] max-479:top-auto max-479:bottom-0">
      <svg xmlns="http://www.w3.org/2000/svg" width="634" height="957" viewBox="0 0 634 957" fill="none">
        <path d="M475.84 797.5H634L634 957H475.84V797.5ZM475.84 797.5L475.84 638M475.84 797.5L317.679 797.5L317.679 638H475.84M475.84 638L475.84 478.5M475.84 638L634 638L634 478.5H475.84M475.84 478.5L475.84 319M475.84 478.5L317.679 478.5L317.679 319H475.84M475.84 319L475.84 159.501M475.84 319L634 319.001L634 159.501L475.84 159.501M475.84 159.501L475.84 6.90146e-06L317.679 0L317.679 159.5L475.84 159.501ZM159.16 797.5H317.32V957H159.16V797.5ZM159.16 797.5L159.16 638M159.16 797.5L1.00001 797.5V638H159.16M159.16 638L159.16 478.5M159.16 638L317.32 638V478.5H159.16M159.16 478.5L159.16 319M159.16 478.5L1.00001 478.5V319L159.16 319M159.16 319L159.16 159.501M159.16 319L317.32 319.001V159.501L159.16 159.501M159.16 159.501L159.16 4.64542e-05L1.00001 3.95528e-05V159.5L159.16 159.501Z" stroke="url(#paint0_linear_aboutv2_right)" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round" />
        <defs>
          <linearGradient id="paint0_linear_aboutv2_right" x1="0.979538" y1="396.992" x2="634" y2="400.841" gradientUnits="userSpaceOnUse">
            <stop stop-color="white" stop-opacity="0" />
            <stop offset="1" stop-color="white" stop-opacity="0.05" />
          </linearGradient>
        </defs>
      </svg>
    </div>

    <!-- Gradient blur left -->
    <div class="aboutv2-gradient-left absolute bg-brand-primary rounded-[848px]"></div>

    <!-- Gradient blur right -->
    <div class="aboutv2-gradient-right absolute bg-brand-primary rounded-[848px]"></div>
  </div>
</section>

<style>
  /* === Main wrapper === */
  .aboutv2-wrapper {
    gap: 24px;
  }

  /* === Section title === */
  .aboutv2-section-title {
    max-width: 450px;
  }

  /* === Excerpt === */
  .aboutv2-excerpt {
    max-width: 500px;
  }

  /* === List block === */
  .aboutv2-list-block {
    gap: 20px;
    margin-top: 24px;
  }

  .aboutv2-list-item {
    padding-left: 40px;
  }

  /* === Fun Facts wrapper === */
  .funfact-v2-wrapper {
    margin-top: 40px;
  }

  .funfact-v2-label {
    font-size: 20px;
    line-height: 1.4;
    margin-top: 18px;
  }

  /* === CTA button wrapper === */
  .aboutv2-btn-wrap {
    margin-top: 40px;
  }

  /* === Banner block === */
  .aboutv2-banner-block {
    /* no extra base styles needed */
  }

  .aboutv2-banner {
    border-radius: 14px;
  }

  .aboutv2-overlay-img {
    width: 100%;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
    position: absolute;
    top: auto;
    right: 0;
    bottom: -20px;
    left: 0;
  }

  /* === Gradient shapes === */
  .aboutv2-gradient-left {
    opacity: 0.4;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    bottom: 0;
    left: -320px;
  }

  .aboutv2-gradient-right {
    opacity: 0.4;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    top: 0;
    right: -300px;
  }

  /* ============= min-1280 ============= */
  @media (min-width: 1280px) {
    .aboutv2-wrapper {
      gap: 32px;
    }

    .aboutv2-section-title {
      max-width: 557px;
    }

    .aboutv2-excerpt {
      max-width: 600px;
    }

    .aboutv2-list-block {
      gap: 30px;
      margin-top: 36px;
    }

    .aboutv2-list-item {
      font-size: 20px;
    }

    .funfact-v2-wrapper {
      margin-top: 54px;
    }

    .funfact-v2-label {
      margin-top: 24px;
    }

    .aboutv2-btn-wrap {
      margin-top: 44px;
    }

    .aboutv2-overlay-img {
      max-width: 490px;
      bottom: -41px;
    }

    .aboutv2-gradient-left {
      width: 750px;
      height: 500px;
      left: -350px;
    }

    .aboutv2-gradient-right {
      width: 750px;
      height: 500px;
      right: -390px;
    }
  }

  /* ============= min-1440 ============= */
  @media (min-width: 1440px) {
    .aboutv2-wrapper {
      gap: 46px;
    }

    .aboutv2-excerpt {
      max-width: 660px;
    }

    .aboutv2-btn-wrap {
      margin-top: 54px;
    }

    .aboutv2-overlay-img {
      max-width: 524px;
    }

    .aboutv2-gradient-left {
      width: 848px;
      height: 628px;
      left: -442px;
    }

    .aboutv2-gradient-right {
      width: 848px;
      height: 628px;
      right: -424px;
    }
  }

  /* ============= max-991 ============= */
  @media (max-width: 991px) {
    .aboutv2-wrapper {
      gap: 40px;
      flex-wrap: wrap;
      justify-content: flex-start;
    }

    .aboutv2-excerpt {
      max-width: 600px;
    }

    .aboutv2-list-item {
      padding-left: 34px;
    }

    .funfact-v2-wrapper {
      flex-wrap: wrap;
    }

    .aboutv2-banner-block {
      margin-left: auto;
      margin-right: auto;
    }

    .aboutv2-banner {
      object-fit: cover;
      margin-left: auto;
      margin-right: auto;
    }

    .aboutv2-overlay-img {
      max-width: 450px;
      margin-left: auto;
      margin-right: auto;
      bottom: 0;
    }

    .aboutv2-gradient-left {
      width: 500px;
      height: 400px;
    }

    .aboutv2-gradient-right {
      width: 500px;
      height: 400px;
    }
  }

  /* ============= max-767 ============= */
  @media (max-width: 767px) {
    .aboutv2-wrapper {
      justify-content: center;
    }

    .aboutv2-list-item {
      padding-left: 30px;
    }

    .funfact-v2-label {
      margin-top: 16px;
    }

    .aboutv2-btn-wrap {
      margin-top: 32px;
    }

    .aboutv2-banner-block {
      max-width: 450px;
    }

    .aboutv2-overlay-img {
      max-width: 90%;
    }

    .aboutv2-gradient-left {
      width: 420px;
      height: 300px;
    }

    .aboutv2-gradient-right {
      width: 400px;
      height: 300px;
    }
  }

  /* ============= max-479 ============= */
  @media (max-width: 479px) {
    .aboutv2-wrapper {
      gap: 30px;
    }

    .funfact-v2-wrapper {
      gap: 20px;
    }

    .aboutv2-gradient-left {
      width: 400px;
      height: 200px;
    }

    .aboutv2-gradient-right {
      width: 360px;
      height: 200px;
    }
  }

  @media (min-width: 992px) and (max-width: 1199px) {
    .aboutv2-inline-primary {
      font-size: 20px;
    }
  }
</style>
