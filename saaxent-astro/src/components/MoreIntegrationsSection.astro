---
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';
import IntegrationCard from './IntegrationCard.astro';
import PrimaryButton from './PrimaryButton.astro';
import { integrationItems } from '../data/integrations';

const { excludeSlug = '' } = Astro.props;

const items = integrationItems
  .filter((item) => item.href !== `/integration/${excludeSlug}`)
  .slice(0, 3);
---

<section class="mi-section relative overflow-hidden">
  <Container>
    <div class="relative z-[1]">
      <!-- Section Title -->
      <div class="mi-title-block reveal">
        <SectionTitle
          badge="Integration"
          title="Explore More Of Our"
          highlight="Integration"
        />
      </div>

      <!-- Integration Grid + CTA -->
      <div class="reveal delay-1">
        <div class="mi-grid">
          {items.map((item) => (
            <IntegrationCard
              name={item.name}
              type={item.type}
              description={item.description}
              icon={item.icon}
              href={item.href}
            />
          ))}
        </div>

        <!-- CTA Button -->
        <div class="mi-cta-wrap flex justify-center">
          <PrimaryButton href="/integration">
            All Integration
            <svg xmlns="http://www.w3.org/2000/svg" width="23" height="18" viewBox="0 0 23 18" fill="none" class="ml-10">
              <g clip-path="url(#clip_mi_cta)">
                <path d="M21.0834 9.0376L13.8959 1.8501M21.0834 9.0376L13.8959 16.2251M21.0834 9.0376L8.50525 9.0376M1.91671 9.0376L4.9115 9.0376" stroke="currentColor" stroke-width="1.79688" stroke-linecap="round" stroke-linejoin="round" />
              </g>
              <defs>
                <clipPath id="clip_mi_cta">
                  <rect width="17.25" height="23" fill="currentColor" transform="translate(23 0.412598) rotate(90)" />
                </clipPath>
              </defs>
            </svg>
          </PrimaryButton>
        </div>
      </div>
    </div>
  </Container>

  <!-- Section lines (14 vertical lines) -->
  <div class="pointer-events-none absolute inset-0 flex justify-between" aria-hidden="true">
    {Array.from({ length: 14 }).map(() => (
      <div class="h-full bg-border-light" style="width: 0.5px; opacity: 0.03;"></div>
    ))}
  </div>

  <!-- Gradient blur shape (left only on detail page) -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="mi-gradient-left absolute bg-brand-primary rounded-full"></div>
  </div>
</section>

<style>
  /* === Section padding-top only === */
  .mi-section {
    padding-top: 70px;
  }

  /* === Section title margin-bottom === */
  .mi-title-block {
    margin-bottom: 95px;
  }

  /* === Integration Grid === */
  .mi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-column-gap: 30px;
    grid-row-gap: 115px;
  }

  /* === CTA Button Wrapper === */
  .mi-cta-wrap {
    margin-top: 60px;
  }

  /* === Gradient Left === */
  .mi-gradient-left {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    margin-top: auto;
    margin-bottom: auto;
    top: 0;
    bottom: 0;
    left: -420px;
  }

  /* ============= min-1280 ============= */
  @media (min-width: 1280px) {
    .mi-section {
      padding-top: 90px;
    }

    .mi-title-block {
      margin-bottom: 115px;
    }

    .mi-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .mi-gradient-left {
      width: 750px;
      height: 500px;
      bottom: 100px;
      left: -450px;
    }
  }

  /* ============= min-1440 ============= */
  @media (min-width: 1440px) {
    .mi-section {
      padding-top: 100px;
    }

    .mi-cta-wrap {
      margin-top: 80px;
    }

    .mi-gradient-left {
      width: 848px;
      height: 628px;
      bottom: 120px;
      left: -552px;
    }
  }

  /* ============= max-991 ============= */
  @media (max-width: 991px) {
    .mi-section {
      padding-top: 50px;
    }

    .mi-cta-wrap {
      margin-top: 50px;
    }
  }

  /* ============= max-767 ============= */
  @media (max-width: 767px) {
    .mi-section {
      padding-top: 30px;
    }

    .mi-grid {
      grid-template-columns: 1fr;
      grid-row-gap: 90px;
    }

    .mi-cta-wrap {
      margin-top: 40px;
    }
  }

  /* ============= max-479 ============= */
  @media (max-width: 479px) {
    .mi-section {
      padding-top: 24px;
    }

    .mi-grid {
      grid-row-gap: 70px;
    }

    .mi-cta-wrap {
      margin-top: 30px;
    }
  }
</style>
