---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import { featureItems } from '../data/features';

const feature1 = featureItems[0];
const feature2 = featureItems[1];
const feature3 = featureItems[2];
---

<section class="overflow-hidden relative py-90 min-1280:py-110 min-1440:py-130 max-991:py-70 max-767:py-50">
  <Container>
    <div class="relative z-[1]">
      <div class="features-wrapper flex flex-col mt-40 min-1280:mt-44 min-1440:mt-54 max-767:mt-32">

        {/* ====== BLOCK V1: FEATURED (content-left, banner-right) ====== */}
        {feature1 && (
          <div class="relative reveal">
            <div class="relative z-[1]">
              <div class="v1-grid">
                {/* Content */}
                <div class="v1-content">
                  {feature1.tag && (
                    <div class="inline-block text-white border border-solid border-white rounded-20 mb-16 py-[3px] px-20">{feature1.tag}</div>
                  )}
                  <h3 class="feat-heading">{feature1.title}</h3>
                  <p class="mt-18 mb-0">{feature1.description}</p>
                  <a href={feature1.href} class="feat-btn feat-btn-mt inline-flex items-center rounded-40 border-2 border-solid border-brand-primary bg-brand-primary text-white no-underline relative overflow-hidden hover:text-brand-primary">
                    <span class="relative z-[2] flex items-center gap-10 max-767:gap-6">
                      <span>Learn More</span>
                      <span class="flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="19" viewBox="0 0 18 19" fill="none">
                          <g clip-path="url(#clip_fsc_v1)">
                            <path d="M16.5 9.8584L10.875 4.2334M16.5 9.8584L10.875 15.4834M16.5 9.8584L6.65625 9.8584M1.5 9.8584L3.84375 9.8584" stroke="currentColor" stroke-width="1.875" stroke-linecap="round" stroke-linejoin="round"/>
                          </g>
                          <defs>
                            <clipPath id="clip_fsc_v1">
                              <rect width="18" height="18" fill="currentColor" transform="translate(18 0.858398) rotate(90)"/>
                            </clipPath>
                          </defs>
                        </svg>
                      </span>
                    </span>
                    <span class="feat-btn-overlay"></span>
                  </a>
                </div>
                {/* Banner */}
                <div class="v1-banner">
                  {typeof feature1.image.src !== 'string' && (
                    <Image src={feature1.image.src} alt={feature1.image.alt} class="v1-image h-auto max-w-full" />
                  )}
                  {feature1.chart && typeof feature1.chart.src !== 'string' && (
                    <Image src={feature1.chart.src} alt={feature1.chart.alt} class="v1-chart h-auto max-w-full absolute" />
                  )}
                </div>
              </div>
            </div>
          </div>
        )}

        {/* ====== BLOCK V2: STANDARD (banner-left, content-right) ====== */}
        {feature2 && (
          <div class="relative reveal delay-1">
            <div class="relative z-[1]">
              <div class="v2-grid">
                {/* Banner (comes first = left side) */}
                <div class="v2-banner">
                  {typeof feature2.image.src !== 'string' && (
                    <Image src={feature2.image.src} alt={feature2.image.alt} class="v2-image h-auto max-w-full absolute" />
                  )}
                  {feature2.chart && typeof feature2.chart.src !== 'string' && (
                    <Image src={feature2.chart.src} alt={feature2.chart.alt} class="v2-chart h-auto max-w-full absolute rounded-10" />
                  )}
                </div>
                {/* Content */}
                <div class="v1-content">
                  {feature2.tag && (
                    <div class="inline-block text-white border border-solid border-white rounded-20 mb-16 py-[3px] px-20">{feature2.tag}</div>
                  )}
                  <h3 class="feat-heading">{feature2.title}</h3>
                  <p class="mt-18 mb-0">{feature2.description}</p>
                  <a href={feature2.href} class="feat-btn feat-btn-mt inline-flex items-center rounded-40 border-2 border-solid border-brand-primary bg-brand-primary text-white no-underline relative overflow-hidden hover:text-brand-primary">
                    <span class="relative z-[2] flex items-center gap-10 max-767:gap-6">
                      <span>Learn More</span>
                      <span class="flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="19" viewBox="0 0 18 19" fill="none">
                          <g clip-path="url(#clip_fsc_v2)">
                            <path d="M16.5 9.8584L10.875 4.2334M16.5 9.8584L10.875 15.4834M16.5 9.8584L6.65625 9.8584M1.5 9.8584L3.84375 9.8584" stroke="currentColor" stroke-width="1.875" stroke-linecap="round" stroke-linejoin="round"/>
                          </g>
                          <defs>
                            <clipPath id="clip_fsc_v2">
                              <rect width="18" height="18" fill="currentColor" transform="translate(18 0.858398) rotate(90)"/>
                            </clipPath>
                          </defs>
                        </svg>
                      </span>
                    </span>
                    <span class="feat-btn-overlay"></span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* ====== BLOCK V3: STANDARD (content-left, banner-right) ====== */}
        {feature3 && (
          <div class="relative reveal delay-2">
            <div class="relative z-[1]">
              <div class="v3-grid">
                {/* Content */}
                <div class="v3-content">
                  {feature3.tag && (
                    <div class="inline-block text-white border border-solid border-white rounded-20 mb-16 py-[3px] px-20">{feature3.tag}</div>
                  )}
                  <h3 class="feat-heading">{feature3.title}</h3>
                  <p class="mt-18 mb-0">{feature3.description}</p>
                  <a href={feature3.href} class="feat-btn feat-btn-mt inline-flex items-center rounded-40 border-2 border-solid border-brand-primary bg-brand-primary text-white no-underline relative overflow-hidden hover:text-brand-primary">
                    <span class="relative z-[2] flex items-center gap-10 max-767:gap-6">
                      <span>Learn More</span>
                      <span class="flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="19" viewBox="0 0 18 19" fill="none">
                          <g clip-path="url(#clip_fsc_v3)">
                            <path d="M16.5 9.8584L10.875 4.2334M16.5 9.8584L10.875 15.4834M16.5 9.8584L6.65625 9.8584M1.5 9.8584L3.84375 9.8584" stroke="currentColor" stroke-width="1.875" stroke-linecap="round" stroke-linejoin="round"/>
                          </g>
                          <defs>
                            <clipPath id="clip_fsc_v3">
                              <rect width="18" height="18" fill="currentColor" transform="translate(18 0.858398) rotate(90)"/>
                            </clipPath>
                          </defs>
                        </svg>
                      </span>
                    </span>
                    <span class="feat-btn-overlay"></span>
                  </a>
                </div>
                {/* Banner */}
                <div class="v3-banner">
                  {typeof feature3.image.src !== 'string' && (
                    <Image src={feature3.image.src} alt={feature3.image.alt} class="v3-image h-auto max-w-full relative" />
                  )}
                  {feature3.chart && typeof feature3.chart.src !== 'string' && (
                    <Image src={feature3.chart.src} alt={feature3.chart.alt} class="v3-chart h-auto max-w-full absolute" />
                  )}
                </div>
              </div>
            </div>
          </div>
        )}

      </div>
    </div>
  </Container>

  {/* ====== SECTION LINE DECORATIVES (14 vertical lines) ====== */}
  <div class="absolute inset-0 flex justify-between pointer-events-none" aria-hidden="true">
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
    <div class="section-line"></div>
  </div>

  {/* ====== GRADIENT BACKGROUND SHAPES ====== */}
  <div aria-hidden="true">
    <div class="gradient-left absolute rounded-full bg-brand-primary"></div>
    <div class="gradient-right-top absolute rounded-full bg-brand-primary"></div>
    <div class="gradient-right-bottom absolute rounded-full bg-brand-primary"></div>
  </div>
</section>

<style>
  /* ============================================================
     FEATURES WRAPPER
     ============================================================ */
  .features-wrapper {
    gap: 100px;
  }
  @media (min-width: 1280px) {
    .features-wrapper {
      gap: 120px;
    }
  }
  @media (min-width: 1440px) {
    .features-wrapper {
      gap: 140px;
    }
  }
  @media (max-width: 991px) {
    .features-wrapper {
      gap: 60px;
    }
  }
  @media (max-width: 767px) {
    .features-wrapper {
      gap: 40px;
    }
  }

  /* ============================================================
     SECTION LINES
     ============================================================ */
  .section-line {
    opacity: 0.03;
    background-color: #dcdcdc;
    width: 0.5px;
    height: 100%;
  }

  /* ============================================================
     FEATURE HEADING (shared)
     ============================================================ */
  .feat-heading {
    color: #ffffff;
  }
  @media (max-width: 479px) {
    .feat-heading {
      font-size: 20px;
    }
  }

  /* ============================================================
     V1 GRID: FEATURED (content-left, banner-right)
     ============================================================ */
  .v1-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    justify-content: space-between;
  }
  @media (max-width: 991px) {
    .v1-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      place-items: center;
    }
  }

  /* V1 Content */
  .v1-content {
    max-width: 400px;
  }
  @media (min-width: 1280px) {
    .v1-content {
      max-width: 485px;
    }
  }
  @media (max-width: 991px) {
    .v1-content {
      max-width: none;
    }
  }

  /* V1 Banner Block */
  .v1-banner {
    box-sizing: border-box;
    background-color: #162342;
    border-radius: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    justify-self: end;
    position: relative;
    width: 450px;
    height: 420px;
    padding: 28px 28px 60px;
  }
  @media (min-width: 1280px) {
    .v1-banner {
      width: 480px;
      height: 420px;
      padding: 43px 43px 87px;
    }
  }
  @media (max-width: 991px) {
    .v1-banner {
      width: 480px;
      height: 420px;
      margin-left: auto;
      margin-right: auto;
    }
  }
  @media (max-width: 767px) {
    .v1-banner {
      justify-content: flex-end;
      align-items: center;
      width: 100%;
      max-width: 480px;
      padding-right: 20px;
    }
  }
  @media (max-width: 479px) {
    .v1-banner {
      gap: 24px;
      justify-content: center;
      align-items: flex-start;
      max-width: 360px;
      height: 400px;
      padding-bottom: 30px;
      padding-left: 16px;
      padding-right: 16px;
    }
  }

  /* V1 Image */
  .v1-image {
    max-width: 260px;
  }
  @media (min-width: 1280px) {
    .v1-image {
      max-width: none;
    }
  }
  @media (max-width: 991px) {
    .v1-image {
      max-width: none;
    }
  }
  @media (max-width: 767px) {
    .v1-image {
      max-width: 240px;
      margin-right: 20px;
    }
  }
  @media (max-width: 479px) {
    .v1-image {
      width: 100%;
      max-width: 200px;
      margin-right: 0;
    }
  }

  /* V1 Chart */
  .v1-chart {
    max-width: 200px;
    bottom: 30px;
    left: -30px;
  }
  @media (min-width: 1280px) {
    .v1-chart {
      max-width: 240px;
      bottom: 43px;
      left: -43px;
    }
  }
  @media (min-width: 1440px) {
    .v1-chart {
      max-width: none;
    }
  }
  @media (max-width: 991px) {
    .v1-chart {
      max-width: none;
      left: -80px;
    }
  }
  @media (max-width: 767px) {
    .v1-chart {
      max-width: 200px;
      bottom: 60px;
      left: 30px;
    }
  }
  @media (max-width: 479px) {
    .v1-chart {
      width: 100%;
      max-width: 180px;
      bottom: 40px;
      left: auto;
      right: 20px;
    }
  }

  /* ============================================================
     V2 GRID: STANDARD (banner-left, content-right)
     ============================================================ */
  .v2-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    justify-content: space-between;
  }
  @media (max-width: 991px) {
    .v2-grid {
      grid-template-columns: 1fr;
      gap: 60px;
      place-items: start center;
    }
  }
  @media (max-width: 479px) {
    .v2-grid {
      gap: 50px;
    }
  }

  /* V2 Banner Block */
  .v2-banner {
    box-sizing: border-box;
    background-color: #162342;
    border-radius: 24px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    position: relative;
    width: 440px;
    height: 420px;
    padding: 28px 28px 60px;
  }
  @media (min-width: 1280px) {
    .v2-banner {
      width: 480px;
      height: 420px;
      padding: 43px 43px 87px;
    }
  }
  @media (max-width: 1265px) {
    .v2-banner {
      width: 400px;
    }
  }
  @media (max-width: 1199px) {
    .v2-banner {
      width: 400px;
    }
  }
  @media (max-width: 991px) {
    .v2-banner {
      justify-content: flex-end;
      align-items: center;
      width: 440px;
      height: 420px;
      order: 2;
    }
  }
  @media (max-width: 767px) {
    .v2-banner {
      justify-content: flex-end;
      align-items: center;
      width: 100%;
      max-width: 480px;
      padding-right: 20px;
    }
  }
  @media (max-width: 479px) {
    .v2-banner {
      justify-content: flex-end;
      align-items: flex-end;
      max-width: 360px;
      height: 320px;
      padding: 16px 16px 20px;
    }
  }

  /* V2 Image (absolute, extends right of banner) */
  .v2-image {
    right: -80px;
  }
  @media (min-width: 1280px) {
    .v2-image {
      top: 36px;
      right: -110px;
    }
  }
  @media (min-width: 1440px) {
    .v2-image {
      top: 43px;
      right: -133px;
    }
  }
  @media (max-width: 991px) {
    .v2-image {
      max-width: 400px;
    }
  }
  @media (max-width: 767px) {
    .v2-image {
      max-width: 400px;
      right: 0;
    }
  }
  @media (max-width: 479px) {
    .v2-image {
      width: 100%;
      max-width: 260px;
      right: auto;
    }
  }

  /* V2 Chart (absolute, inside banner) */
  .v2-chart {
    max-width: 220px;
    top: 70px;
    left: 30px;
  }
  @media (min-width: 1280px) {
    .v2-chart {
      max-width: 250px;
      top: 81px;
    }
  }
  @media (max-width: 991px) {
    .v2-chart {
      max-width: none;
      top: auto;
      bottom: 10%;
      left: -50px;
    }
  }
  @media (max-width: 767px) {
    .v2-chart {
      max-width: 200px;
      top: auto;
      bottom: 40px;
      left: 20px;
    }
  }
  @media (max-width: 479px) {
    .v2-chart {
      width: 100%;
      max-width: 140px;
      top: 40px;
      bottom: auto;
    }
  }

  /* ============================================================
     V3 GRID: STANDARD (content-left, banner-right)
     ============================================================ */
  .v3-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    justify-content: space-between;
  }
  @media (max-width: 991px) {
    .v3-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
  @media (max-width: 767px) {
    .v3-grid {
      justify-items: center;
    }
  }

  /* V3 Content */
  .v3-content {
    max-width: 400px;
  }
  @media (min-width: 1280px) {
    .v3-content {
      max-width: 500px;
    }
  }
  @media (min-width: 1440px) {
    .v3-content {
      max-width: 550px;
    }
  }
  @media (max-width: 991px) {
    .v3-content {
      max-width: none;
    }
  }

  /* V3 Banner Block */
  .v3-banner {
    box-sizing: border-box;
    background-color: #162342;
    border-radius: 24px;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    justify-self: end;
    position: relative;
    width: 450px;
    height: 420px;
    padding: 28px 28px 60px;
  }
  @media (min-width: 1280px) {
    .v3-banner {
      width: 480px;
      height: 420px;
      padding: 43px 43px 87px;
    }
  }
  @media (max-width: 1265px) {
    .v3-banner {
      width: 400px;
    }
  }
  @media (max-width: 1199px) {
    .v3-banner {
      width: 400px;
    }
  }
  @media (max-width: 991px) {
    .v3-banner {
      justify-content: flex-start;
      align-items: center;
      width: 450px;
      height: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }
  @media (max-width: 767px) {
    .v3-banner {
      gap: 20px;
      justify-content: flex-end;
      align-items: flex-start;
      width: 100%;
      max-width: 480px;
      padding-bottom: 30px;
      padding-left: 16px;
      padding-right: 16px;
    }
  }
  @media (max-width: 479px) {
    .v3-banner {
      justify-content: center;
      align-items: flex-start;
      height: 360px;
    }
  }

  /* V3 Image (relative, shifted right) */
  .v3-image {
    right: 110px;
  }
  @media (min-width: 1440px) {
    .v3-image {
      width: 100%;
      min-width: 428px;
    }
  }
  @media (max-width: 991px) {
    .v3-image {
      max-width: 350px;
      right: 0;
    }
  }
  @media (max-width: 767px) {
    .v3-image {
      right: 0;
    }
  }
  @media (max-width: 479px) {
    .v3-image {
      width: 100%;
    }
  }

  /* V3 Chart (absolute, bottom-right) */
  .v3-chart {
    right: 28px;
    bottom: 35px;
  }
  @media (min-width: 1280px) {
    .v3-chart {
      bottom: 54px;
      right: 43px;
    }
  }
  @media (max-width: 991px) {
    .v3-chart {
      max-width: 200px;
      bottom: 10px;
      right: 5px;
    }
  }
  @media (max-width: 767px) {
    .v3-chart {
      width: 100%;
      max-width: 160px;
      bottom: 40px;
      left: 20px;
      right: auto;
    }
  }
  @media (max-width: 479px) {
    .v3-chart {
      max-width: 140px;
      margin-top: 16px;
      right: 0;
      left: auto;
    }
  }

  /* ============================================================
     FEATURE BUTTON (primary-button-block.small-size)
     ============================================================ */
  .feat-btn {
    font-size: 24px;
    line-height: 1.33;
    padding: 10px 22px;
  }
  @media (min-width: 1280px) {
    .feat-btn {
      padding: 12px 24px;
    }
  }
  @media (max-width: 991px) {
    .feat-btn {
      font-size: 22px;
    }
  }
  @media (max-width: 767px) {
    .feat-btn {
      font-size: 20px;
      padding: 8px 18px;
    }
  }
  @media (max-width: 479px) {
    .feat-btn {
      font-size: 18px;
    }
  }

  /* Button margin-top */
  .feat-btn-mt {
    margin-top: 25px;
  }
  @media (min-width: 1280px) {
    .feat-btn-mt {
      margin-top: 35px;
    }
  }

  /* Button overlay (white sweep from left on hover) */
  .feat-btn-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #fff;
    border-radius: 40px;
    transform: translateX(-120%);
    transition: transform 0.5s ease;
  }
  .feat-btn:hover .feat-btn-overlay {
    transform: translateX(0);
  }

  /* ============================================================
     GRADIENT BACKGROUND SHAPES
     ============================================================ */

  /* Left gradient */
  .gradient-left {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    margin-top: auto;
    margin-bottom: auto;
    top: 0;
    bottom: 0;
    left: -420px;
  }
  @media (min-width: 1280px) {
    .gradient-left {
      width: 750px;
      height: 500px;
      bottom: 100px;
      left: -450px;
    }
  }
  @media (min-width: 1440px) {
    .gradient-left {
      width: 848px;
      height: 628px;
      bottom: 120px;
      left: -552px;
    }
  }
  @media (max-width: 991px) {
    .gradient-left {
      width: 500px;
      height: 400px;
    }
  }
  @media (max-width: 767px) {
    .gradient-left {
      width: 500px;
      height: 300px;
    }
  }
  @media (max-width: 479px) {
    .gradient-left {
      width: 400px;
      height: 200px;
      left: -300px;
    }
  }

  /* Right-top gradient */
  .gradient-right-top {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    top: 70px;
    right: -300px;
  }
  @media (min-width: 1280px) {
    .gradient-right-top {
      width: 750px;
      height: 500px;
      top: 80px;
      right: -360px;
    }
  }
  @media (min-width: 1440px) {
