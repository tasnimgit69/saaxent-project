---
import { Image } from 'astro:assets';
import Container from './Container.astro';

const { member } = Astro.props;
---

<section class="relative overflow-hidden py-90 min-1280:py-110 min-1440:py-130 max-991:py-70 max-767:py-50">
  <Container>
    <div class="relative z-[1]">
      <!-- Primary Detail: Image + Content -->
      <div class="td-primary-wrapper reveal">
        <!-- Image block -->
        <div>
          <div class="td-image-wrap">
            {typeof member.image.src !== 'string' && (
              <Image
                src={member.image.src}
                alt={member.image.alt}
                class="td-detail-image"
              />
            )}
          </div>
        </div>

        <!-- Content panel -->
        <div class="td-content">
          <div class="max-w-[470px] max-479:max-w-full">
            <div class="text-white mb-8 text-[20px] font-medium leading-[1.2] min-1280:mb-12 min-1280:text-[24px]">Hello, I'm</div>
            <h2 class="text-white mb-8 min-1280:mb-12 min-1280:text-[36px] min-1440:text-[40px] max-991:mb-5 max-991:text-[28px] max-479:text-[24px]">{member.name}</h2>
            <div class="relative z-[1] text-white">{member.role}</div>
            <div class="td-separator"></div>

            <!-- Info detail list -->
            <div class="td-info-detail">
              <ul>
                <li><strong>Department:</strong> {member.department}</li>
                <li><strong>Experience:</strong> {member.experienceYears}</li>
                <li>
                  <strong>Email:</strong>
                  <a href={`mailto:${member.email}`}>{member.email}</a>
                </li>
                <li>
                  <strong>Phone:</strong>
                  <a href={`tel:${member.phone}`}>{member.phone}</a>
                </li>
              </ul>
            </div>

            <div class="td-separator"></div>

            <!-- Social links -->
            <div class="flex gap-30 max-991:gap-20 max-767:gap-14">
              {member.socials.facebook && (
                <a href={member.socials.facebook} aria-label="Facebook" class="inline-block">
                  <div class="flex items-center justify-center w-[40px] h-[40px] rounded-20 text-white bg-glass-border-alpha transition-[background-color] duration-300 hover:bg-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 26 26" fill="none">
                      <path d="M14.8583 14.3445H17.4221L18.4477 10.2424H14.8583V8.19139C14.8583 7.1351 14.8583 6.14035 16.9094 6.14035H18.4477V2.6946C18.1133 2.6505 16.8509 2.55103 15.5177 2.55103C12.7335 2.55103 10.7562 4.25031 10.7562 7.37097V10.2424H7.67969V14.3445H10.7562V23.0614H14.8583V14.3445Z" fill="currentColor" />
                    </svg>
                  </div>
                </a>
              )}
              {member.socials.twitter && (
                <a href={member.socials.twitter} aria-label="X" class="inline-block">
                  <div class="flex items-center justify-center w-[40px] h-[40px] rounded-20 text-white bg-glass-border-alpha transition-[background-color] duration-300 hover:bg-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 26 26" fill="none">
                      <path d="M3.57617 22.036L11.3172 14.295M11.3172 14.295L3.57617 3.57666H8.70378L14.2945 11.3177M11.3172 14.295L16.9079 22.036H22.0355L14.2945 11.3177M22.0355 3.57666L14.2945 11.3177" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
                    </svg>
                  </div>
                </a>
              )}
              {member.socials.linkedin && (
                <a href={member.socials.linkedin} aria-label="LinkedIn" class="inline-block">
                  <div class="flex items-center justify-center w-[40px] h-[40px] rounded-20 text-white bg-glass-border-alpha transition-[background-color] duration-300 hover:bg-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
                      <path d="M5.39541 3C4.34798 3 3.50017 3.84929 3.5 4.89431C3.5 5.94034 4.34781 6.78946 5.39558 6.78946C6.44047 6.78946 7.28946 5.94034 7.28946 4.89431C7.28946 3.84913 6.4403 3 5.39541 3Z" fill="currentColor" />
                      <path d="M3.5 8.68408H7.28946V20.9998H3.5V8.68408Z" fill="currentColor" />
                      <path d="M16.7617 8.68408C14.8404 8.68408 13.5521 9.68025 13.0247 10.6249H12.9719V8.98289H9.1838H9.18359V20.9998H13.1298V15.055C13.1298 13.4877 13.4454 11.9696 15.5002 11.9696C17.5255 11.9696 17.5525 13.7621 17.5525 15.1555V20.9996H21.4993V14.4084C21.4993 11.1729 20.7611 8.68408 16.7617 8.68408Z" fill="currentColor" />
                    </svg>
                  </div>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- Bio summary -->
      <p class="max-w-[850px] text-[20px] min-1280:max-w-full reveal delay-1">{member.bio}</p>

      <!-- Skills & Experience -->
      <div class="td-secondary-wrapper">
        <!-- Skills section -->
        <div class="reveal delay-2">
          <div>
            <h3 class="text-white mb-16 font-normal min-1440:mb-20">Skills & Expertise</h3>
            {member.skillsSection.description && (
              <p class="text-ink-body text-body leading-[1.55]">{member.skillsSection.description}</p>
            )}
          </div>
          <div class="td-skill-grid">
            {member.skillsSection.items.map((skill: { icon: { src: any; alt: string }; percentage: string; label: string }) => (
              <div class="flex flex-col items-center justify-center gap-[15px] text-center">
                <div class="flex items-center justify-center w-[60px] h-[60px] rounded-8 bg-surface-review-card shadow-card-sm">
                  {typeof skill.icon.src !== 'string' && (
                    <Image
                      src={skill.icon.src}
                      alt={skill.icon.alt}
                      width={30}
                      height={30}
                    />
                  )}
                </div>
                <h3 class="text-white mb-0 text-[18px] font-normal leading-[28px] min-1280:text-[20px]">{skill.percentage} - {skill.label}</h3>
              </div>
            ))}
          </div>
        </div>

        <!-- Experience section -->
        <div class="reveal delay-3">
          <div>
            <h3 class="text-white mb-16 font-normal min-1440:mb-20">Experience</h3>
            {member.experienceSection.description && (
              <p class="text-ink-body text-body leading-[1.55]">{member.experienceSection.description}</p>
            )}
          </div>
          <div class="td-experience-grid">
            {member.experienceSection.items.map((exp: { icon: { src: any; alt: string }; title: string; dateRange: string; company: string }) => (
              <div class="td-experience-block">
                <div class="td-experience-logo-block">
                  {typeof exp.icon.src !== 'string' && (
                    <Image
                      src={exp.icon.src}
                      alt={exp.icon.alt}
                      class="td-experience-logo"
                    />
                  )}
                </div>
                <div>
                  <h4 class="text-white mt-0 mb-0 text-[20px] font-normal leading-[1.4] max-767:text-[18px]">{exp.title}</h4>
                  <p class="text-ink-body mb-0 text-[16px] leading-[1.55]">{exp.dateRange} <strong class="font-semibold text-white">{exp.company}</strong></p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div class="td-contact-form-wrapper reveal delay-4">
        <span class="inline-block rounded-19 border border-solid border-white px-20 py-3 text-sm font-medium text-white">
          Get Free Quote
        </span>
        <h2 class="text-white mt-24 mb-0 min-1440:mt-32 max-991:mt-20 max-767:mt-16 min-1280:text-[40px] max-767:text-[30px] max-479:text-[25px]">Have a Project in Mind?</h2>
        <div class="mt-32 min-1440:mt-40 max-991:mt-[26px] max-767:mt-20">
          <form class="flex flex-col gap-24">
            <div class="td-form-row">
              <div class="w-full">
                <label class="block text-white mb-12 text-[20px] font-medium leading-[1.4] max-479:text-[18px]" for="td-name">Name</label>
                <input type="text" id="td-name" name="name" placeholder="Enter your name" class="td-input font-sans text-[18px] leading-[1.3] text-surface-primary placeholder:text-ink-muted placeholder:text-[16px] min-1280:placeholder:text-[18px] focus:border-brand-primary focus:outline-none max-479:text-[16px]" />
              </div>
              <div class="w-full td-field-gap-left">
                <label class="block text-white mb-12 text-[20px] font-medium leading-[1.4] max-479:text-[18px]" for="td-phone">Phone</label>
                <input type="tel" id="td-phone" name="phone" placeholder="Enter your number..." class="td-input font-sans text-[18px] leading-[1.3] text-surface-primary placeholder:text-ink-muted placeholder:text-[16px] min-1280:placeholder:text-[18px] focus:border-brand-primary focus:outline-none max-479:text-[16px]" />
              </div>
            </div>
            <div class="td-form-row">
              <div class="w-full">
                <label class="block text-white mb-12 text-[20px] font-medium leading-[1.4] max-479:text-[18px]" for="td-email">Email</label>
                <input type="email" id="td-email" name="email" placeholder="Enter your email here..." class="td-input font-sans text-[18px] leading-[1.3] text-surface-primary placeholder:text-ink-muted placeholder:text-[16px] min-1280:placeholder:text-[18px] focus:border-brand-primary focus:outline-none max-479:text-[16px]" />
              </div>
              <div class="w-full td-field-gap-left">
                <label class="block text-white mb-12 text-[20px] font-medium leading-[1.4] max-479:text-[18px]" for="td-subject">Subject</label>
                <input type="text" id="td-subject" name="subject" placeholder="Write your subject..." class="td-input font-sans text-[18px] leading-[1.3] text-surface-primary placeholder:text-ink-muted placeholder:text-[16px] min-1280:placeholder:text-[18px] focus:border-brand-primary focus:outline-none max-479:text-[16px]" />
              </div>
            </div>
            <div class="w-full">
              <label class="block text-white mb-12 text-[20px] font-medium leading-[1.4] max-479:text-[18px]" for="td-message">Message</label>
              <textarea id="td-message" name="message" placeholder="Write your message..." class="td-textarea font-sans text-[18px] text-surface-body placeholder:text-neutral-500 focus:border-brand-primary focus:outline-none max-479:text-[16px]"></textarea>
            </div>
            <div class="mt-20 max-767:mt-14">
              <button type="submit" class="inline-flex items-center bg-brand-primary text-white border-none rounded-8 cursor-pointer font-sans text-[22px] leading-[1.33] transition-colors duration-300 hover:bg-white hover:text-surface-primary px-28 py-18 min-1280:text-[24px] min-1440:px-[52px]">
                Submit Now
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </Container>

  <!-- Section lines (14 vertical lines) -->
  <div class="pointer-events-none absolute inset-0 flex justify-between" aria-hidden="true">
    {Array.from({ length: 14 }).map(() => (
      <div class="h-full bg-border-light" style="width: 0.5px; opacity: 0.03;"></div>
    ))}
  </div>

  <!-- Gradient blur shapes -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="td-gradient-left-top absolute rounded-full bg-brand-primary"></div>
    <div class="td-gradient-left-bottom absolute rounded-full bg-brand-primary"></div>
    <div class="td-gradient-right-top absolute rounded-full bg-brand-primary"></div>
    <div class="td-gradient-right-bottom absolute rounded-full bg-brand-primary"></div>
  </div>
</section>

<style>
  /* Primary detail wrapper - CSS Grid */
  .td-primary-wrapper {
    display: grid;
    grid-template-columns: .7fr 1fr;
    gap: 40px;
    margin-bottom: 42px;
    overflow: hidden;
  }

  /* Image wrap */
  .td-image-wrap {
    border-radius: 20px;
    overflow: hidden;
  }

  .td-detail-image {
    width: 100%;
    height: auto;
  }

  /* Content panel */
  .td-content {
    z-index: 1;
    background-color: #071e31;
    background-image: url('/images/team-member-section-BG-shape.png');
    background-position: 100%;
    background-size: auto;
    background-repeat: no-repeat;
    border-radius: 20px;
    padding: 40px;
    position: relative;
  }

  /* Separator */
  .td-separator {
    background-color: #4f4f4f4d;
    width: 100%;
    height: 1px;
    margin-top: 20px;
    margin-bottom: 20px;
  }

  /* Info detail list */
  .td-info-detail ul {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 0;
    padding-left: 0;
    list-style-type: none;
  }

  .td-info-detail li {
    color: #fff;
    display: flex;
    flex-direction: row;
    justify-content: flex-start;
    align-items: center;
    font-size: 18px;
    line-height: 1.4;
  }

  .td-info-detail strong {
    min-width: 140px;
    font-size: 18px;
    font-weight: 500;
  }

  .td-info-detail a {
    color: #fff;
    text-decoration: none;
    transition: color 0.3s;
  }

  .td-info-detail a:hover {
    color: #5542f6;
  }

  /* Secondary wrapper (skills + experience) */
  .td-secondary-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-top: 42px;
  }

  /* Skills grid */
  .td-skill-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 20px;
  }

  /* Experience grid */
  .td-experience-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 25px;
    margin-top: 20px;
  }

  .td-experience-block {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    align-items: center;
  }

  .td-experience-logo-block {
    background-color: #2b2742;
    border-radius: 8px;
    flex: none;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 68px;
    height: 68px;
    box-shadow: 2px 6px 20px #00000014;
  }

  .td-experience-logo {
    width: 30px;
    height: 30px;
  }

  /* Contact form wrapper */
  .td-contact-form-wrapper {
    background-color: #071e31;
    border-radius: 20px;
    margin-top: 100px;
    padding: 40px;
  }

  .td-form-row {
    display: flex;
  }

  .td-field-gap-left {
    margin-left: 32px;
  }

  .td-input {
    border: 0.5px solid #071e31;
    background-color: #fff;
    border-radius: 12px;
    width: 100%;
    min-height: 68px;
    margin-bottom: 0;
    padding: 21px 20px;
    box-sizing: border-box;
  }

  .td-textarea {
    border: 0.5px solid #4f4f4f;
    border-radius: 12px;
    width: 100%;
    min-height: 236px;
    margin-bottom: 0;
    padding: 21px 20px;
    resize: vertical;
    box-sizing: border-box;
  }

  /* Gradient shapes */
  .td-gradient-left-top {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    top: 300px;
    left: -420px;
  }

  .td-gradient-left-bottom {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    top: auto;
    bottom: 10px;
    left: -420px;
  }

  .td-gradient-right-top {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    z-index: 1;
    top: 50px;
    right: -300px;
  }

  .td-gradient-right-bottom {
    opacity: 0.3;
    filter: blur(800px);
    width: 600px;
    height: 450px;
    top: auto;
    bottom: 400px;
    right: -300px;
  }

  /* ===== min-1280 ===== */
  @media (min-width: 1280px) {
    .td-primary-wrapper {
      grid-template-columns: .75fr 1fr;
      gap: 62px;
      margin-bottom: 50px;
    }


    .td-info-detail ul {
      gap: 20px;
    }

    .td-info-detail li {
      font-size: 20px;
    }

    .td-info-detail strong {
      min-width: 160px;
      font-size: 20px;
    }

    .td-secondary-wrapper {
      margin-top: 50px;
    }

    .td-skill-grid {
      margin-top: 28px;
    }

    .td-experience-grid {
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      margin-top: 24px;
    }

    .td-experience-logo {
      width: auto;
      height: auto;
    }

    .td-contact-form-wrapper {
      margin-top: 120px;
    }

    .td-gradient-left-top {
      width: 750px;
      height: 500px;
      top: 360px;
      left: -450px;
    }

    .td-gradient-left-bottom {
      width: 750px;
      height: 500px;
      left: -450px;
    }

    .td-gradient-right-top {
      width: 750px;
      height: 500px;
      top: 80px;
      right: -360px;
    }

    .td-gradient-right-bottom {
      width: 750px;
      height: 500px;
      bottom: 450px;
      right: -360px;
    }
  }

  /* ===== min-1440 ===== */
  @media (min-width: 1440px) {
    .td-primary-wrapper {
      grid-template-columns: .7fr 1fr;
      margin-bottom: 58px;
    }

    .td-separator {
      margin-top: 26px;
      margin-bottom: 26px;
    }

    .td-info-detail ul {
      gap: 24px;
    }

    .td-secondary-wrapper {
      margin-top: 58px;
    }

    .td-contact-form-wrapper {
      margin-top: 140px;
      padding: 60px 60px 44px;
    }

    .td-gradient-left-top {
      width: 848px;
      height: 628px;
      top: 440px;
      left: -552px;
    }

    .td-gradient-left-bottom {
      width: 848px;
      height: 628px;
      left: -552px;
    }

    .td-gradient-right-top {
      width: 848px;
      height: 628px;
      top: 63px;
      right: -424px;
    }

    .td-gradient-right-bottom {
      width: 848px;
      height: 628px;
      bottom: 524px;
      right: -424px;
    }
  }

  /* ===== max-991 ===== */
  @media (max-width: 991px) {
    .td-primary-wrapper {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .td-content {
      padding: 25px 20px;
    }

    .td-secondary-wrapper {
      grid-template-columns: 1.15fr 1fr;
      gap: 30px;
    }

    .td-experience-grid {
      gap: 15px;
      grid-template-columns: 1fr;
    }

    .td-contact-form-wrapper {
      margin-top: 80px;
      padding-left: 30px;
      padding-right: 30px;
    }
  }

  /* ===== max-767 ===== */
  @media (max-width: 767px) {
    .td-primary-wrapper {
      grid-template-columns: 1fr;
      place-items: start stretch;
      margin-bottom: 30px;
    }

    .td-separator {
      margin-top: 15px;
      margin-bottom: 15px;
    }

    .td-secondary-wrapper {
      grid-template-columns: 1.15fr;
      gap: 35px;
      margin-top: 30px;
    }

    .td-skill-grid {
      margin-top: 16px;
    }

    .td-experience-grid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-top: 16px;
    }

    .td-experience-logo-block {
      width: 52px;
      height: 52px;
    }

    .td-experience-block {
      gap: 12px;
    }

    .td-contact-form-wrapper {
      margin-top: 60px;
    }

    .td-form-row {
      flex-wrap: wrap;
      gap: 22px;
    }

    .td-field-gap-left {
      margin-left: 0;
    }

    .td-input {
      min-height: 60px;
      padding: 16px;
    }

    .td-textarea {
      min-height: 180px;
      padding: 16px;
    }

    .td-gradient-right-top {
      right: -450px;
    }
  }

  /* ===== max-479 ===== */
  @media (max-width: 479px) {
    

    .td-content {
      width: 100%;
    }

    .td-info-detail li {
      font-size: 16px;
    }

    .td-info-detail strong {
      min-width: 110px;
      font-size: 16px;
    }

    .td-experience-logo-block {
      width: 60px;
      height: 60px;
    }

    .td-experience-grid {
      grid-template-columns: 1fr;
    }

    .td-experience-block {
      gap: 16px;
    }

    .td-textarea {
      min-height: 160px;
    }

    .td-contact-form-wrapper {
      padding: 30px 16px;
    }
  }
</style>
