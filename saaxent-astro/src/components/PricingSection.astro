---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';
import { pricingSection } from '../data/home-v1';
import { pricingPlans } from '../data/pricing';
import { resolveImage } from '../utils/resolveImage';

const { showTitle = true } = Astro.props;

const checkDark = resolveImage('/images/Pricing-Menu-Check-Mark-dark.png');
const checkWhite = resolveImage('/images/Pricing-Menu-Check-Mark-white.png');
---

<section class="overflow-hidden relative py-90 min-1280:py-110 min-1440:py-130 max-991:py-70 max-767:py-50">
  <!-- Section vertical lines -->
  <div class="absolute top-0 left-0 w-full h-full flex justify-between pointer-events-none" aria-hidden="true">
    {Array.from({ length: 14 }).map(() => (
      <div class="opacity-[0.03] bg-[#dcdcdc] h-full" style="width: 0.5px;"></div>
    ))}
  </div>

  <Container>
    <div class="relative z-10">
      <!-- Section Title -->
      {showTitle && (
        <div class="reveal">
          <SectionTitle
            badge={pricingSection.badge}
            title={pricingSection.title}
            highlight={pricingSection.titleHighlight}
            titleAfter={pricingSection.titleAfter}
            description={pricingSection.description}
            titleClass="max-w-[580px] min-1280:max-w-[650px] max-991:max-w-[500px] max-767:max-w-[450px]"
            descriptionClass="max-w-[630px]"
          />
        </div>
      )}

      <!-- Pricing wrapper -->
      <div class="relative z-10 mt-40 min-1280:mt-44 min-1440:mt-54 max-991:mt-32 reveal delay-1">
        <!-- Pricing table tabs - flex layout -->
        <div class="flex justify-between items-stretch gap-30 max-991:flex-row-reverse max-991:flex-wrap-reverse" data-pricing-tabs>

          <!-- Tab content panes (left side) -->
          <div class="pricing-tabs-content">
            {pricingPlans.map((plan, i) => (
              <div
                class={`bg-surface-white bg-shimmer rounded-20 relative ${i === 0 ? '' : 'hidden'}`}
                data-pricing-panel
                role="tabpanel"
                aria-label={plan.name}
              >
                <div class="tab-pane-inner relative z-10">
                  <h3 class="text-surface-body font-medium mt-0 mb-0">Included Features</h3>
                  <div class="pricing-divider bg-ink-placeholder h-[1px]"></div>
                  <ul class="flex flex-col gap-30 mb-0 pl-0 list-none">
                    {plan.features.map((feature) => (
                      <li class="text-surface-body bg-[url('/images/pricing-content-list-check-mark.svg')] bg-no-repeat bg-[position:0_5px] pricing-list-item">
                        {feature}
                      </li>
                    ))}
                  </ul>
                  <div class="flex pricing-btn-wrap">
                    <a
                      href={plan.ctaHref}
                      class="pricing-cta-link inline-flex items-center border border-solid border-surface-body text-surface-body rounded-40 relative overflow-hidden no-underline"
                    >
                      <span class="relative z-[2] flex items-center gap-10 max-479:gap-6">
                        <span>{plan.ctaLabel}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="19" viewBox="0 0 18 19" fill="none" class="flex items-center justify-center">
                          <g clip-path={`url(#clip_pricing_arrow_${i})`}>
                            <path d="M16.5 9.8584L10.875 4.2334M16.5 9.8584L10.875 15.4834M16.5 9.8584L6.65625 9.8584M1.5 9.8584L3.84375 9.8584" stroke="currentColor" stroke-width="1.875" stroke-linecap="round" stroke-linejoin="round" />
                          </g>
                          <defs>
                            <clipPath id={`clip_pricing_arrow_${i}`}>
                              <rect width="18" height="18" fill="currentColor" transform="translate(18 0.858398) rotate(90)" />
                            </clipPath>
                          </defs>
                        </svg>
                      </span>
                      <span class="pricing-cta-overlay"></span>
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Tab menu (right side) -->
          <div class="pricing-tabs-menu flex flex-col items-start" role="tablist">
            {pricingPlans.map((plan, i) => (
              <button
                class="pricing-tab-btn rounded-20 w-full p-0 border-none bg-transparent cursor-pointer"
                data-pricing-tab
                data-index={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                <div
                  class={`pricing-tab-link-wrap rounded-20 w-full box-border inline-flex items-center relative ${i === 0 ? 'bg-brand-primary text-white' : 'bg-surface-white text-surface-body'}`}
                  data-tab-wrap
                >
                  <div class="flex pricing-link-block">
                    <div class="flex-none relative">
                      {typeof checkWhite !== 'string' && (
                        <Image
                          src={checkWhite}
                          alt="Included"
                          width={32}
                          height={32}
                          class={`h-auto w-auto ${i === 0 ? '' : 'opacity-0'}`}
                          data-check-white
                        />
                      )}
                      {typeof checkDark !== 'string' && (
                        <Image
                          src={checkDark}
                          alt="Included"
                          width={32}
                          height={32}
                          class={`absolute top-0 left-0 h-auto w-auto ${i === 0 ? 'opacity-0' : ''}`}
                          data-check-dark
                        />
                      )}
                    </div>
                    <div class="text-left pricing-link-info-wrap">
                      <h3 class="pricing-tab-plan-title mt-0 mb-0">{plan.name}</h3>
                      <p
                        class={`pricing-link-excerpt mb-0 ${i === 0 ? 'text-white opacity-80' : 'text-ink-placeholder'}`}
                        data-tab-excerpt
                      >
                        {plan.tagline}
                      </p>
                    </div>
                  </div>
                  <div class="pricing-range-block">
                    <div class="prize-rate">
                      {plan.price}<span class="prize-time font-normal">{plan.period}</span>
                    </div>
                  </div>
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Container>

  <!-- Gradient decorative shapes -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="pricing-gradient-left absolute rounded-full bg-brand-primary"></div>
    <div class="pricing-gradient-right absolute rounded-full bg-brand-primary"></div>
  </div>
</section>

<style>
  /* === Tab content panes (left side) === */
  .pricing-tabs-content {
    width: 465px;
    margin-left: 0;
    margin-right: auto;
  }

  .tab-pane-inner {
    padding: 40px 35px;
  }

  .pricing-divider {
    margin-top: 24px;
    margin-bottom: 24px;
  }

  .pricing-list-item {
    padding-left: 30px;
    font-size: 22px;
    line-height: 1.28;
  }

  .pricing-btn-wrap {
    margin-top: 40px;
  }

  /* === CTA button === */
  .pricing-cta-link {
    padding: 13px 22px;
    font-size: 24px;
    line-height: 1.33;
    font-weight: 400;
    transition: border-color 0.5s, color 0.5s;
  }

  .pricing-cta-link:hover {
    border-color: #5542f6;
    color: #ffffff;
  }

  .pricing-cta-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #5542f6;
    border-radius: 40px;
    transform: translateX(-120%);
    transition: transform 0.5s ease;
  }

  .pricing-cta-link:hover .pricing-cta-overlay {
    transform: translateX(0);
  }

  /* === Tab menu (right side) === */
  .pricing-tabs-menu {
    gap: 30px;
    flex: 0 auto;
    width: 465px;
    margin-left: auto;
    margin-right: 0;
  }

  .pricing-tab-link-wrap {
    gap: 20px;
    padding: 35px 20px;
  }

  /* Tab button h3 — only inherit color from parent wrap, keep h3 base typography */
  .pricing-tab-plan-title {
    color: inherit;
  }

  .pricing-link-block {
    gap: 12px;
  }

  .pricing-link-excerpt {
    max-width: 300px;
    margin-top: 16px;
    font-size: 18px;
    line-height: 1.55;
    font-weight: 400;
  }

  .prize-rate {
    font-size: 38px;
    font-weight: 600;
    line-height: 1.2;
    color: inherit;
  }

  .prize-time {
    font-size: 18px;
  }

  /* === Gradient shapes === */
  .pricing-gradient-left {
    opacity: 0.4;
    filter: blur(800px);
    width: 500px;
    height: 350px;
    bottom: -71px;
    left: -250px;
  }

  .pricing-gradient-right {
    opacity: 0.4;
    filter: blur(800px);
    width: 500px;
    height: 350px;
    top: 0;
    right: -250px;
  }

  /* ============= min-1280 ============= */
  @media (min-width: 1280px) {
    .pricing-tabs-content {
      width: 570px;
    }

    .tab-pane-inner {
      padding: 55px;
    }

    .pricing-divider {
      margin-top: 34px;
      margin-bottom: 34px;
    }

    .pricing-list-item {
      padding-left: 40px;
      font-size: 28px;
    }

    .pricing-btn-wrap {
      margin-top: 44px;
    }

    .pricing-cta-link {
      padding: 17px 28px;
    }

    .pricing-tabs-menu {
      width: 570px;
    }

    .pricing-tab-link-wrap {
      padding: 38px 30px 37px;
    }

    .pricing-link-block {
      gap: 20px;
    }

    .pricing-link-excerpt {
      max-width: 328px;
    }

    .prize-rate {
      font-size: 44px;
    }

    .pricing-gradient-left {
      width: 680px;
      height: 550px;
      left: -340px;
    }

    .pricing-gradient-right {
      width: 680px;
      height: 550px;
      right: -340px;
    }
  }

  /* ============= min-1440 ============= */
  @media (min-width: 1440px) {
    .pricing-tabs-content {
      width: 630px;
    }

    .pricing-btn-wrap {
      margin-top: 54px;
    }

    .pricing-tabs-menu {
      width: 630px;
    }

    .pricing-gradient-left {
      width: 848px;
      height: 628px;
      left: -424px;
    }

    .pricing-gradient-right {
      width: 848px;
      height: 628px;
      right: -424px;
    }
  }

  /* ============= max-991 ============= */
  @media (max-width: 991px) {
    .pricing-tabs-content {
      width: 100%;
      margin-top: 30px;
      margin-left: auto;
      margin-right: auto;
    }

    .tab-pane-inner {
      padding-left: 20px;
      padding-right: 20px;
    }

    .pricing-list-item {
      font-size: 20px;
    }

    .pricing-btn-wrap {
      margin-top: 32px;
    }

    .pricing-tabs-menu {
      gap: 20px;
      width: auto;
      margin-left: auto;
      margin-right: auto;
    }

    .pricing-tab-link-wrap {
      justify-content: flex-start;
      align-items: flex-start;
      padding-top: 20px;
      padding-bottom: 20px;
    }

    .pricing-link-excerpt {
      max-width: 380px;
      margin-top: 20px;
    }

    .pricing-range-block {
      position: absolute;
      top: 20px;
      right: 20px;
    }

    .pricing-gradient-left {
      width: 300px;
      height: 250px;
      left: -150px;
    }

    .pricing-gradient-right {
      width: 300px;
      height: 250px;
      right: -150px;
    }
  }

  /* ============= 768–991 ============= */
  @media (min-width: 768px) and (max-width: 991px) {
    .pricing-cta-link {
      font-size: 20px;
    }
  }

  /* ============= max-767 ============= */
  @media (max-width: 767px) {
    .pricing-cta-link {
      font-size: 18px;
    }
  }

  /* ============= max-479 ============= */
  @media (max-width: 479px) {
    .pricing-cta-link {
      padding-left: 20px;
      padding-right: 20px;
    }

    .pricing-link-block {
      flex-wrap: wrap;
    }

    .pricing-link-info-wrap {
      margin-top: 10px;
    }

    .pricing-link-excerpt {
      margin-top: 10px;
    }

    .prize-rate {
      font-size: 32px;
    }
  }
</style>

<script>
  const container = document.querySelector('[data-pricing-tabs]');
  if (container) {
    const tabs = container.querySelectorAll('[data-pricing-tab]');
    const panels = container.querySelectorAll('[data-pricing-panel]');

    function activateTab(index: number) {
      tabs.forEach((t, i) => {
        const isActive = i === index;
        const wrap = t.querySelector('[data-tab-wrap]') as HTMLElement;
        const checkWhiteEl = t.querySelector('[data-check-white]') as HTMLElement;
        const checkDarkEl = t.querySelector('[data-check-dark]') as HTMLElement;
        const excerpt = t.querySelector('[data-tab-excerpt]') as HTMLElement;

        t.setAttribute('aria-selected', String(isActive));

        if (wrap) {
          wrap.classList.remove('bg-brand-primary', 'text-white', 'bg-surface-white', 'text-surface-body');
          if (isActive) {
            wrap.classList.add('bg-brand-primary', 'text-white');
          } else {
            wrap.classList.add('bg-surface-white', 'text-surface-body');
          }
        }

        if (checkWhiteEl) {
          checkWhiteEl.classList.toggle('opacity-0', !isActive);
        }

        if (checkDarkEl) {
          checkDarkEl.classList.toggle('opacity-0', isActive);
        }

        if (excerpt) {
          excerpt.classList.remove('text-white', 'opacity-80', 'text-ink-placeholder');
          if (isActive) {
            excerpt.classList.add('text-white', 'opacity-80');
          } else {
            excerpt.classList.add('text-ink-placeholder');
          }
        }
      });

      panels.forEach((p, i) => {
        if (i === index) {
          p.classList.remove('hidden');
        } else {
          p.classList.add('hidden');
        }
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const index = parseInt((tab as HTMLElement).dataset.index || '0', 10);
        activateTab(index);
      });

      tab.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        const current = parseInt((tab as HTMLElement).dataset.index || '0', 10);
        let next = current;
        if (key === 'ArrowDown' || key === 'ArrowRight') {
          e.preventDefault();
          next = (current + 1) % tabs.length;
        } else if (key === 'ArrowUp' || key === 'ArrowLeft') {
          e.preventDefault();
          next = (current - 1 + tabs.length) % tabs.length;
        } else if (key === 'Home') {
          e.preventDefault();
          next = 0;
        } else if (key === 'End') {
          e.preventDefault();
          next = tabs.length - 1;
        } else {
          return;
        }
        activateTab(next);
        (tabs[next] as HTMLElement).focus();
      });
    });
  }
</script>
