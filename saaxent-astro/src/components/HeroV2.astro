---
import { Image } from 'astro:assets';
import Container from './Container.astro';
import { heroV2 } from '../data/home-v2';
---

<section class="hero-section-v2 relative overflow-hidden bg-hero-v2 pt-180 pb-100 min-1280:pt-210 min-1280:pb-130 min-1440:pt-238 max-991:pt-160 max-991:pb-80 max-767:pt-120 max-767:pb-60 max-479:pb-50">
  <Container>
    <div class="hero-wrapper-v2 relative z-[1] flex flex-col items-center">

      <!-- Header block -->
      <div class="flex flex-col items-center">
        <!-- Badge -->
        <div class="hero-fade-up inline-block rounded-19 bg-brand-primary px-20 py-4 font-sans text-sm font-medium text-white max-767:mb-10">
          {heroV2.badge}
        </div>

        <!-- Title -->
        <h1 class="hero-fade-up hero-fade-up-delay-1 hero-v2-title text-center mt-20 max-767:mt-14">
          {heroV2.title}{' '}
          <span class="inline-flex items-center justify-center bg-[url('/images/title-highlight-shape.svg')] bg-[position:50%_80%] bg-no-repeat overflow-hidden min-1280:bg-[position:50%_83%]">
            {heroV2.titleHighlight}
          </span>
        </h1>

        <!-- Excerpt -->
        <p class="hero-fade-up hero-fade-up-delay-2 hero-v2-excerpt text-center mb-0">
          {heroV2.description}
        </p>

        <!-- Button wrapper -->
        <div class="hero-fade-up hero-fade-up-delay-3 hero-btn-wrapper flex items-center justify-center max-991:flex-wrap">

          <!-- Primary button -->
          <a
            href={heroV2.primaryCta.href}
            class="hero-inline-primary inline-flex items-center justify-center border-2 border-solid border-brand-primary bg-brand-primary text-white rounded-40 px-22 py-13 text-h4 font-normal no-underline relative overflow-hidden transition-colors duration-[400ms] hover:text-brand-primary before:content-[''] before:absolute before:inset-0 before:bg-white before:rounded-40 before:-translate-x-full before:transition-transform before:duration-[400ms] hover:before:translate-x-0 min-1280:px-28 min-1280:py-15 min-1440:py-16 max-991:text-[22px] max-767:px-20 max-767:text-[20px] max-479:px-18 max-479:py-11 max-479:text-[18px]"
          >
            <span class="relative z-[2] flex items-center justify-center gap-10 max-767:gap-6">
              <span>{heroV2.primaryCta.label}</span>
              <span class="flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="23" height="18" viewBox="0 0 23 18" fill="none">
                  <g clip-path="url(#clip0_herov2_primary)">
                    <path d="M21.0834 9.0376L13.8959 1.8501M21.0834 9.0376L13.8959 16.2251M21.0834 9.0376L8.50525 9.0376M1.91671 9.0376L4.9115 9.0376" stroke="currentColor" stroke-width="1.79688" stroke-linecap="round" stroke-linejoin="round" />
                  </g>
                  <defs>
                    <clipPath id="clip0_herov2_primary">
                      <rect width="17.25" height="23" fill="currentColor" transform="translate(23 0.412598) rotate(90)" />
                    </clipPath>
                  </defs>
                </svg>
              </span>
            </span>
          </a>

          <!-- Outline button -->
          <a
            href={heroV2.secondaryCta.href}
            class="hero-inline-outline inline-flex items-center justify-center border border-solid border-white text-white rounded-40 px-22 py-13 text-h4 font-normal no-underline relative overflow-hidden transition-[color,border-color] duration-[400ms] hover:border-brand-primary hover:text-brand-primary before:content-[''] before:absolute before:inset-0 before:bg-white before:rounded-40 before:-translate-x-full before:transition-transform before:duration-[400ms] hover:before:translate-x-0 min-1280:px-28 max-991:text-[18px] max-767:px-20 max-479:px-18 max-479:py-11"
          >
            <span class="relative z-[2]">{heroV2.secondaryCta.label}</span>
          </a>
        </div>
      </div>

      <!-- Banner wrapper - 3 column grid -->
      <div class="hero-v2-banner-wrapper">
        <div class="herov2-banner-wrap flex flex-col items-center gap-10">
          {typeof heroV2.images.growth.src !== 'string' && (
            <Image
              src={heroV2.images.growth.src}
              alt={heroV2.images.growth.alt}
              loading="eager"
              class="hero-v2-banner-one h-auto max-w-full reveal delay-1"
            />
          )}
        </div>
        <div class="herov2-banner-wrap flex flex-col items-center gap-10">
          {typeof heroV2.images.customerSticker.src !== 'string' && (
            <Image
              src={heroV2.images.customerSticker.src}
              alt={heroV2.images.customerSticker.alt}
              class="hero-v2-user-sticker h-auto max-w-full reveal delay-2"
            />
          )}
          {typeof heroV2.images.salesComparison.src !== 'string' && (
            <Image
              src={heroV2.images.salesComparison.src}
              alt={heroV2.images.salesComparison.alt}
              class="hero-v2-sales-sticker h-auto max-w-full reveal delay-3"
            />
          )}
        </div>
        <div class="herov2-banner-wrap flex flex-col items-center gap-10">
          {typeof heroV2.images.monthly.src !== 'string' && (
            <Image
              src={heroV2.images.monthly.src}
              alt={heroV2.images.monthly.alt}
              class="hero-v2-banner-two h-auto max-w-full reveal delay-4"
            />
          )}
        </div>
      </div>

    </div>
  </Container>

  <!-- Decorative background shapes -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Left grid SVG -->
    <div class="absolute top-0 left-0 max-w-[500px] max-h-[600px] min-1280:max-w-[600px] min-1280:max-h-[700px] max-991:max-w-[400px] max-991:max-h-[500px] max-767:max-w-[300px] max-767:max-h-[400px] max-479:max-w-[200px] max-479:max-h-[300px]">
      <svg xmlns="http://www.w3.org/2000/svg" width="660" height="995" viewBox="0 0 660 995" fill="none">
        <path d="M164.651 827.667H0L7.27066e-06 994H164.651V827.667ZM164.651 827.667L164.652 661.334M164.651 827.667L329.303 827.667L329.303 661.334H164.652M164.652 661.334L164.651 495M164.652 661.334L1.19915e-05 661.333L4.72083e-06 495H164.651M164.651 495L164.651 328.667M164.651 495L329.303 495L329.303 328.667H164.651M164.651 328.667L164.651 162.334M164.651 328.667L1.19915e-05 328.667L4.72083e-06 162.334L164.651 162.334M164.651 162.334L164.652 -3.99999L329.303 -4L329.303 162.333L164.651 162.334ZM494.328 827.667H329.676V994H494.328V827.667ZM494.328 827.667L494.327 661.334M494.328 827.667L658.979 827.667V661.334H494.327M494.327 661.334L494.328 495M494.327 661.334L329.676 661.333V495H494.328M494.328 495L494.327 328.667M494.328 495L658.979 495V328.667L494.327 328.667M494.327 328.667L494.328 162.334M494.327 328.667L329.676 328.667V162.334L494.328 162.334M494.328 162.334L494.327 -3.99995L658.979 -3.99996V162.333L494.328 162.334Z" stroke="url(#paint0_linear_herov2_left)" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round" />
        <defs>
          <linearGradient id="paint0_linear_herov2_left" x1="659" y1="410" x2="1.45908e-05" y2="414" gradientUnits="userSpaceOnUse">
            <stop stop-color="#17223B" stop-opacity="0" />
            <stop offset="1" stop-color="white" stop-opacity="0.05" />
          </linearGradient>
        </defs>
      </svg>
    </div>

    <!-- Right grid SVG -->
    <div class="absolute top-0 right-0 max-w-[500px] max-h-[600px] min-1280:max-w-[600px] min-1280:max-h-[700px] max-991:max-w-[400px] max-991:max-h-[500px] max-991:top-auto max-991:bottom-0 max-767:max-w-[300px] max-767:max-h-[400px] max-479:max-w-[200px] max-479:max-h-[300px]">
      <svg xmlns="http://www.w3.org/2000/svg" width="660" height="995" viewBox="0 0 660 995" fill="none">
        <path d="M495.327 827.667H659.979L659.979 994H495.327V827.667ZM495.327 827.667L495.327 661.334M495.327 827.667L330.676 827.667L330.676 661.334H495.327M495.327 661.334L495.327 495M495.327 661.334L659.979 661.333L659.979 495H495.327M495.327 495L495.328 328.667M495.327 495L330.676 495L330.676 328.667H495.328M495.328 328.667L495.327 162.334M495.328 328.667L659.979 328.667L659.979 162.334L495.327 162.334M495.327 162.334L495.327 -3.99999L330.676 -4L330.676 162.333L495.327 162.334ZM165.651 827.667H330.302V994H165.651V827.667ZM165.651 827.667L165.651 661.334M165.651 827.667L1.00006 827.667V661.334H165.651M165.651 661.334L165.651 495M165.651 661.334L330.302 661.333V495H165.651M165.651 495L165.651 328.667M165.651 495L1.00006 495V328.667L165.651 328.667M165.651 328.667L165.651 162.334M165.651 328.667L330.302 328.667V162.334L165.651 162.334M165.651 162.334L165.651 -3.99995L1.00006 -3.99996V162.333L165.651 162.334Z" stroke="url(#paint0_linear_herov2_right)" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round" />
        <defs>
          <linearGradient id="paint0_linear_herov2_right" x1="0.97876" y1="410" x2="659.979" y2="414" gradientUnits="userSpaceOnUse">
            <stop stop-color="#17223B" stop-opacity="0" />
            <stop offset="1" stop-color="white" stop-opacity="0.05" />
          </linearGradient>
        </defs>
      </svg>
    </div>

    <!-- Gradient blur left -->
    <div class="herov2-gradient-left absolute bg-brand-primary rounded-[797px]"></div>

    <!-- Gradient blur right -->
    <div class="herov2-gradient-right absolute bg-brand-primary rounded-[1002px]"></div>
  </div>
</section>

<style>
  /* === Hero wrapper (flex-column, centered) === */
  .hero-wrapper-v2 {
    gap: 80px;
  }

  /* === Hero V2 title === */
  .hero-v2-title {
    max-width: 650px;
  }

  /* === Hero V2 excerpt === */
  .hero-v2-excerpt {
    max-width: 720px;
    margin-top: 16px;
  }

  /* === Button wrapper === */
  .hero-btn-wrapper {
    gap: 20px;
    margin-top: 40px;
  }

  /* === Banner wrapper (3-column grid) === */
  .hero-v2-banner-wrapper {
    gap: 16px;
    grid-template-rows: auto;
    grid-template-columns: 1fr 1fr 1fr;
    grid-auto-columns: 1fr;
    padding-top: 20px;
    padding-bottom: 20px;
    display: grid;
  }

  /* === Banner images === */
  .hero-v2-banner-one,
  .hero-v2-banner-two {
    border-radius: 20px;
  }

  .hero-v2-banner-one {
    animation: hero-v2-banner-one-float 4s ease-in-out infinite;
  }

  .hero-v2-banner-two {
    animation: hero-v2-banner-two-float 4s ease-in-out infinite;
  }

  .hero-v2-user-sticker {
    border-radius: 24px;
    transform: rotate(-6.24deg);
  }

  .hero-v2-sales-sticker {
    border-radius: 20px;
    margin-top: 20px;
    transform: rotate(8.23deg);
  }

  /* === Gradient shapes === */
  .herov2-gradient-left {
    opacity: 0.4;
    filter: blur(1204px);
    width: 500px;
    height: 400px;
    top: 60px;
    left: -280px;
  }

  .herov2-gradient-right {
    opacity: 0.4;
    filter: blur(1202px);
    width: 500px;
    height: 400px;
    top: 200px;
    right: -250px;
  }

  /* === Fade-up animations === */
  @keyframes hero-fade-up {
    0% {
      opacity: 0;
      transform: translateY(40px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-fade-up {
    animation: hero-fade-up 0.8s ease-out forwards;
    opacity: 0;
  }

  .hero-fade-up-delay-1 {
    animation-delay: 0.15s;
  }

  .hero-fade-up-delay-2 {
    animation-delay: 0.3s;
  }

  .hero-fade-up-delay-3 {
    animation-delay: 0.45s;
  }

  /* ============= min-1280 ============= */
  @media (min-width: 1280px) {
    .hero-wrapper-v2 {
      gap: 100px;
    }

    .hero-v2-title {
      max-width: 800px;
    }

    .hero-v2-excerpt {
      max-width: 750px;
    }

    .hero-btn-wrapper {
      gap: 32px;
      margin-top: 44px;
    }

    .herov2-gradient-left {
      width: 680px;
      height: 520px;
      top: 80px;
      left: -280px;
    }

    .herov2-gradient-right {
      width: 700px;
      height: 500px;
      top: 300px;
      right: -380px;
    }
  }

  /* ============= min-1440 ============= */
  @media (min-width: 1440px) {
    .hero-v2-title {
      max-width: 900px;
    }

    .hero-v2-excerpt {
      max-width: 825px;
    }

    .hero-btn-wrapper {
      margin-top: 54px;
    }

    .herov2-gradient-left {
      width: 848px;
      height: 628px;
      top: 105px;
      left: -383px;
    }

    .herov2-gradient-right {
      width: 848px;
      height: 628px;
      top: 418px;
      right: -424px;
    }
  }

  /* ============= max-991 ============= */
  @media (max-width: 991px) {
    .hero-wrapper-v2 {
      flex-wrap: wrap;
    }

    .hero-v2-excerpt {
      max-width: 550px;
    }

    .herov2-gradient-left {
      width: 400px;
      height: 300px;
    }

    .herov2-gradient-right {
      width: 400px;
      height: 300px;
      right: -200px;
    }
  }

  /* ============= max-767 ============= */
  @media (max-width: 767px) {
    .hero-wrapper-v2 {
      gap: 60px;
    }

    .hero-v2-title {
      max-width: none;
    }

    .hero-v2-excerpt {
      margin-top: 10px;
    }

    .hero-btn-wrapper {
      margin-top: 32px;
    }

    .hero-v2-banner-wrapper {
      padding-bottom: 0;
    }

    .herov2-banner-wrap {
      break-inside: avoid;
    }

    .hero-v2-banner-one {
      margin-bottom: 30px;
    }

    .hero-v2-user-sticker {
      margin-top: 10px;
      transform: none;
    }

    .hero-v2-sales-sticker {
      max-width: 180px;
      margin-top: 0;
      margin-bottom: 30px;
      transform: none;
    }
  }

  /* ============= max-479 ============= */
  @media (max-width: 479px) {
    .hero-wrapper-v2 {
      gap: 30px;
    }

    .hero-btn-wrapper {
      gap: 14px;
    }

    .herov2-banner-wrap {
      justify-content: flex-start;
      align-items: flex-start;
    }

    .hero-v2-banner-one,
    .hero-v2-sales-sticker {
      max-width: 140px;
      margin-bottom: 20px;
    }

    .herov2-gradient-left {
      width: 350px;
      height: 200px;
    }

    .herov2-gradient-right {
      width: 300px;
      height: 200px;
    }
  }

  /* === Banner float keyframes === */
  @keyframes hero-v2-banner-one-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(20px); }
  }

  @keyframes hero-v2-banner-two-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  /* === Reduced motion === */
  @media (prefers-reduced-motion: reduce) {
    .hero-fade-up,
    .hero-v2-banner-one,
    .hero-v2-banner-two {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (min-width: 992px) and (max-width: 1199px) {
    .hero-inline-primary,
    .hero-inline-outline {
      font-size: 20px;
    }
  }
</style>
