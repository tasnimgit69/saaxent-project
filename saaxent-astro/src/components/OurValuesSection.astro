  <!-- Background decorative shapes -->
  <div class="pointer-events-none" aria-hidden="true">
    <div class="ov-bg-left absolute bg-brand-primary rounded-full"></div>
    <div class="ov-bg-right absolute bg-brand-primary rounded-full"></div>
  </div>
</section>

<style>
  /* ============================================================
     TITLE
     ============================================================ */
  .ov-title {
    max-width: 550px;
  }

  /* ============================================================
     EXCERPT
     ============================================================ */
  .ov-excerpt {
    max-width: 570px;
  }

  /* ============================================================
     VALUES CARD WRAPPER
     ============================================================ */
  .ov-card-wrapper {
    background-color: #07263f;
    border-radius: 20px;
    justify-content: flex-start;
    align-items: flex-end;
    padding: 40px 30px;
    gap: 30px;
    display: flex;
    overflow: hidden;
  }

  /* ============================================================
     VALUE ITEM
     ============================================================ */
  .ov-icon-wrap {
    background-color: #0c3e67;
    width: 95px;
    height: 95px;
    flex-shrink: 0;
  }

  .ov-value-title {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.28;
    color: #ffffff;
    text-align: center;
  }

  .ov-value-excerpt {
    text-align: center;
    max-width: 320px;
  }

  /* ============================================================
     VERTICAL DIVIDERS
     ============================================================ */
  .ov-vertical-divider {
    background-color: #dcdcdc;
    width: 1px;
    height: 150px;
    flex-shrink: 0;
  }

  /* ============================================================
     FUN FACTS WRAPPER
     ============================================================ */
  .ov-funfact-wrapper {
    border-top: 1px solid #dcdcdc;
    margin-top: 50px;
    padding-top: 50px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 30px;
  }

  /* Fun fact dividers */
  .ov-funfact-divider {
    background-color: gainsboro;
    width: 1px;
    align-self: stretch;
  }

  /* ============================================================
     BACKGROUND SHAPES
     ============================================================ */
  .ov-bg-left {
    opacity: 0.4;
    filter: blur(800px);
    width: 500px;
    height: 400px;
    top: 15%;
    left: -25%;
  }

  .ov-bg-right {
    opacity: 0.4;
    filter: blur(800px);
    width: 500px;
    height: 400px;
    top: 10%;
    right: -300px;
  }

  /* ============================================================
     min-1280
     ============================================================ */
  @media (min-width: 1280px) {
    .ov-title {
      max-width: 600px;
    }

    .ov-card-wrapper {
      padding: 50px 40px;
      gap: 30px;
    }

    .ov-value-title {
      font-size: 28px;
    }

    .ov-vertical-divider {
      height: 125px;
    }

    .ov-bg-left {
      width: 700px;
      height: 500px;
      left: -35%;
    }

    .ov-bg-right {
      width: 700px;
      height: 500px;
      right: -380px;
    }
  }

  /* ============================================================
     min-1440
     ============================================================ */
  @media (min-width: 1440px) {
