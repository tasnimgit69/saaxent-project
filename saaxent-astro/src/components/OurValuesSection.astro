    }
  }

  /* ============================================================
     max-767
     ============================================================ */
  @media (max-width: 767px) {
    .ov-title {
      max-width: none;
    }

    .ov-value-excerpt,
    .ov-value-excerpt-wide {
      max-width: none;
    }

    .ov-vertical-divider {
      display: none;
    }

    .ov-funfact-wrapper {
      flex-wrap: wrap;
      justify-content: center;
    }

    .ov-bg-left {
      width: 350px;
      height: 300px;
    }

