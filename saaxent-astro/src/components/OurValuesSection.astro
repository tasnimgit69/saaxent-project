      max-width: 630px;
    }

    .ov-card-wrapper {
      padding: 60px 55px;
      gap: 55px;
    }

    .ov-funfact-wrapper {
      margin-top: 70px;
      padding-top: 70px;
    }

    .ov-bg-left {
      width: 848px;
      height: 628px;
      left: -424px;
    }

    .ov-bg-right {
      width: 848px;
      height: 628px;
      right: -424px;
    }
  }

  /* ============================================================
     max-991
     ============================================================ */
  @media (max-width: 991px) {
    .ov-card-wrapper {
      flex-wrap: wrap;
      justify-content: center;
    }

    .ov-value-excerpt {
      max-width: 260px;
    }

    .ov-value-excerpt-wide {
      max-width: 325px;
    }

    .ov-divider-second {
      display: none;
    }

