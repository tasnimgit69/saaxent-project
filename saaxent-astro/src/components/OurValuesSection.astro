      <div class="ov-funfact-wrapper reveal delay-4">
        {ourValues.stats.map((stat, i) => (
          <>
            <FunFactCounter value={stat.value} suffix={stat.suffix} label={stat.label} class="text-center" />
            {i < ourValues.stats.length - 1 && (
              <div class="ov-funfact-divider" aria-hidden="true"></div>
            )}
          </>
        ))}
      </div>
