---
import { Image } from 'astro:assets';

const { name, type, description, icon, href } = Astro.props;
---

<div class="ig-item-block relative flex flex-col items-center bg-surface-primary rounded-12">
  <!-- Floating Header Block (absolute, sits above card) -->
  <div class="ig-header-block absolute inline-flex items-center justify-center rounded-12">
    <div class="flex-none flex items-center justify-center w-[65px] h-[65px] rounded-32 bg-white">
      {typeof icon !== 'string' && (
        <Image src={icon} alt={name} class="h-auto" width={40} height={40} />
      )}
    </div>
    <div class="ig-header-info border-l border-solid border-[#6b6b6b] border-t-0 border-b-0 border-b-0 border-r-0">
      <div class="ig-name text-white">{name}</div>
      <div class="ig-type">{type}</div>
    </div>
  </div>

  <!-- Description Content -->
  <div class="flex flex-col items-center justify-start">
    <p class="ig-description text-center mb-0">{description}</p>
    <div class="ig-btn-wrap">
      <a href={href} class="ig-btn inline-flex items-center rounded-40 border-2 border-solid border-brand-primary bg-brand-primary text-white no-underline relative overflow-hidden hover:text-brand-primary">
        <span class="relative z-[2] flex items-center gap-10">
          <span>View Integration</span>
          <span class="flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="19" viewBox="0 0 18 19" fill="none">
              <g clip-path="url(#clip_ig)">
                <path d="M16.5 9.8584L10.875 4.2334M16.5 9.8584L10.875 15.4834M16.5 9.8584L6.65625 9.8584M1.5 9.8584L3.84375 9.8584" stroke="currentColor" stroke-width="1.875" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <defs>
                <clipPath id="clip_ig">
                  <rect width="18" height="18" fill="currentColor" transform="translate(18 0.858398) rotate(90)"/>
                </clipPath>
              </defs>
            </svg>
          </span>
        </span>
        <span class="ig-btn-overlay"></span>
      </a>
    </div>
  </div>
</div>

<style>
  /* Item Block */
  .ig-item-block {
    padding: 102px 40px 30px;
  }

  /* Floating Header */
  .ig-header-block {
    background-color: #19244c;
    gap: 20px;
    padding: 20px 30px;
    inset: -55px auto auto;
  }

  /* Header Info */
  .ig-header-info {
    padding-left: 20px;
  }

  /* Integration Name */
  .ig-name {
    font-family: Outfit, sans-serif;
    font-size: 24px;
    font-weight: 500;
    line-height: 1.28;
    margin-bottom: 10px;
  }

  /* Integration Type */
  .ig-type {
    font-size: 16px;
    line-height: 1.62;
  }

  /* Description */
  .ig-description {
    /* inherits body text styles */
  }

  /* Button Wrapper */
  .ig-btn-wrap {
    margin-top: 40px;
  }

  /* Button */
  .ig-btn {
    font-size: 20px;
    line-height: 1.4;
    padding: 10px 18px;
  }

  /* Button overlay (white sweep) */
  .ig-btn-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: #fff;
    border-radius: 40px;
    transform: translateX(-120%);
    transition: transform 0.5s ease;
  }
  .ig-btn:hover .ig-btn-overlay {
    transform: translateX(0);
  }

  /* ============================================================
     min-1280
     ============================================================ */
  @media (min-width: 1280px) {
    .ig-item-block {
      padding: 102px 27px 36px;
    }

    .ig-header-block {
      padding: 22px 24px;
    }

    .ig-name {
      font-size: 28px;
    }
  }

  /* ============================================================
     min-1440
     ============================================================ */
  @media (min-width: 1440px) {
    .ig-item-block {
      padding: 102px 32px 40px;
    }

    .ig-header-block {
      padding-left: 41px;
      padding-right: 41px;
    }
  }

  /* ============================================================
     max-767
     ============================================================ */
  @media (max-width: 767px) {
    .ig-item-block {
      padding-left: 20px;
      padding-right: 20px;
    }

    .ig-header-block {
      padding-left: 20px;
      padding-right: 20px;
      top: -40px;
    }

    .ig-header-info {
      max-width: 130px;
      padding-left: 12px;
    }

    .ig-name {
      font-size: 22px;
    }
  }

  /* ============================================================
     max-479
     ============================================================ */
  @media (max-width: 479px) {
    .ig-btn {
      font-size: 18px;
    }
  }

  /* ============================================================
     Reduced motion
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .ig-btn-overlay {
      transition: none;
    }
  }
</style>
