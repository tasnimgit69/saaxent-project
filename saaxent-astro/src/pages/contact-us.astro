---
import PageLayout from '../layouts/PageLayout.astro';
import BreadcrumbHero from '../components/BreadcrumbHero.astro';
import ContactSection from '../components/ContactSection.astro';
import CtaSection from '../components/CtaSection.astro';
import { contactBreadcrumb } from '../data/contact';
---

<PageLayout
  title="Contact Us | SaaXent - SaaS Website Template"
  description="Get in touch with the SaaXent team. We're here to help with your business needs."
>
  <BreadcrumbHero
    badge={contactBreadcrumb.badge}
    title={contactBreadcrumb.title}
    highlight={contactBreadcrumb.highlight}
    titleAfter={contactBreadcrumb.titleAfter}
    titleClass="max-w-[600px] min-1280:max-w-[800px] min-1440:max-w-[900px] max-479:max-w-none"
  />
  <ContactSection />
  <CtaSection />
</PageLayout>
